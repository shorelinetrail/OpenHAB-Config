# Copy to /etc/brunt-bridge/secrets.env and fill in. chmod 600. NOT in git.
BRUNT_USER=ste.hornsey@googlemail.com
BRUNT_PASS=your_brunt_password_here

# MQTT broker (old Pi)
MQTT_HOST=192.168.0.40
MQTT_PORT=1883
MQTT_USER=openhabian
MQTT_PASS=your_mosquitto_password_here

# Optional position feedback (openHAB has no stateTopic today -> leave false)
PUBLISH_STATE=false
STATE_POLL_SEC=60

# Flip if blinds end up inverted after a live test
INVERT=false
