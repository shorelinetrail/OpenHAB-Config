/*============ GROUPS ============*/

/* General Groups */

Group gDevices       "Devices"
Group gLighting      "Lighting"                     <lightbulb>     (gDevices)   ["Lighting"]
Group gWeather       "Weather"                      <sun>
Group gVariables     "Variables"                    <settings>      
Group gSetpoints     "Setpoints"                    <settings>     
Group gCharts        "Charts"                       <settings>
Group gTemperature   "Temperature"                  <temperature>    
Group gPressure   "Temperature"                  <temperature>  
Group gOutside   "Temperature"                  <temperature>  
Group gIlluminance   "Iluminance"                   <lightbulb> 
Group gHumidity      "Humidity"                     <humidity> 
Group gPower        "Power"
Group gAverage        "Average"
Group:Number:MIN gTemperatureDelta "Temperature Delta" <temperature>


/* Specific Devices */

Group gHueColour                                     <colorlight>
Group gHueGlass                                      <lightbulb>
Group gSceneControl  "Scene Controller"              <settings>     (gDevices)    ["Scene Controller"]
Group gMultisensor   "Multisensor"                   <lightbulb>     (gDevices)   ["Multisensor"]
Group gPhilipsHue    "Philips Hue"                   <lightbulb>     (gDevices)   ["Hue"]
Group gHueYard       "Yard Lighting"                 <lightbulb>     (gDevices)   ["Yard Lighting"]
Group gHueYardColour "Yard Lighting"                 <colorlight>     (gDevices)   ["Yard Lighting"]
Group gHueYardR       "Rear Yard Lighting"           <lightbulb>     (gDevices)   ["Yard Lighting"]
Group gHueYardRColour "Rear Yard Lighting"           <colorlight>     (gDevices)   ["Yard Lighting"]
Group gHueFront      "Front Door Lighting"           <lightbulb>     (gDevices)   ["Front Door Lighting"]
Group gHueFrontColour "Front Door Lighting"          <colorlight>     (gDevices)  ["Front Door Lighting"] 
Group gSmoke         "Smoke Detection"               <fire>          (gDevices)   ["Smoke"]
// gSmokeAlarm: every detector's binary alarm Item (0=Alarm, 1=OK) - the Fibaro
// FGSD002 channels (smoke/heat/tamper/fault/battalarm, below) plus the shed MQTT
// GY1SA4_smoke/_tamper (mqtt.items). Watched by smoke.rules for alerting + seeding.
Group gSmokeAlarm    "Smoke Alarm Channels"          <fire>
Group gPlugSP1       "Plug Office"                   <energy>        (gDevices)   ["Smart Plugs"]
Group gPlugSP2       "Plug Living Room"              <energy>        (gDevices)   ["Smart Plugs"]
Group gPlugSP3       "Plug Bedroom"                  <energy>        (gDevices)   ["Smart Plugs"]
Group gChristmas     "Christmas Lights"              <lightbulb>
Group gHeatingSP    <heating>
Group gHeatingSP1
Group gHeatingSP2
Group gHeatingSP3
Group gHeatingSP4
Group gHeatingSP5
Group gHeatingSP6
Group gHeatingFault <heating>
Group gSonoff_RSSI
Group gSonoff_IP
Group gSonoff_Uptime
Group gBoiler

Group:Switch:OR(ON, OFF)        gPlugs       "Smart Plugs [(%d)]"
Group:Switch:OR(OFF, ON)        gHeating     "Radiators [(%d)]" <switch>
Group:Switch:OR(ON, OFF)        gSonoff      "Sonoff Relays [(%d)]"
Group:Dimmer                    gHueDimmer   "Dimmer [(%d)]"                <lightbulb>
Group:Dimmer                    gHueKitchen   "Dimmer [(%d)]"                <lightbulb>
Group:Dimmer                    gHueTable   "Dimmer [(%d)]"                <lightbulb>
Group:Number:AVG                gTemperatureAvg "Average Indoor Temperature [%.1f °C]" 	<temperature>
Group:Dimmer                    gBlinds    "Dimmer [(%d)]" <blinds>
Group:Dimmer                    gGBlinds   "Dimmer [(%d)]" <blinds>

/*============ ITEMS ============*/

/* Tasker */
Switch phoneCharging "Phone Wireless Charging Status" <energy>
Switch phoneChargingRelease "Phone Wireless Charging Status" <energy>
Switch phoneChargingDelay "Phone Wireless Charging Status (delayed)" <energy>
Number phoneChargingTimer "Phone Charging Delay Timer [%.0f min]" <energy>

/* Arrival Sensor */

Number XM1AS1_battery "Battery Status [%.0f %%]"
String XM1AS1_presence "Presence Sensor" <switch>
String XM1AS1_presence_S "Ste Present" <switch>
String XM1AS1_presence_J "Jacqui Present" <switch>
Switch XM1AS1_presence_trig "Presence Trigger" <switch>

