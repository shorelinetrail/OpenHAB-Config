Bridge mqtt:broker:mosquitto "Mosquitto Broker" [ host="192.168.0.40", port=1883, secure=false, username="openhabian", password="OHmosquitto*" ] {

  // -----------------------------
  // Positions / Blinds
  // -----------------------------
  Thing topic FB1BE3_position "FB1BE3_position" (mqtt:broker:mosquitto) {
    Channels:
      Type dimmer : FB1BE3_position "Command" [ commandTopic="cmnd/FB1-BE3/POSITION" ]
  }
  Thing topic GL1BE2_position "GL1BE2_position" (mqtt:broker:mosquitto) {
    Channels:
      Type dimmer : GL1BE2_position "Command" [ commandTopic="cmnd/GL1-BE2/POSITION" ]
  }
  Thing topic GO1BE1_position "GO1BE1_position" (mqtt:broker:mosquitto) {
    Channels:
      Type dimmer : GO1BE1_position "Command" [ commandTopic="cmnd/GO1-BE1/POSITION" ]
  }

  // -----------------------------
  // Environmental sensors (SENSOR telemetry)
  // -----------------------------
  Thing topic GO1SS4_temp "GO1SS4_temp" (mqtt:broker:mosquitto) {
    Channels:
      Type number : GO1SS4_temp "Temperature 1" [ stateTopic="tele/GO1-SS4/SENSOR", transformationPattern="JSONPATH:$.BMP280.Temperature" ]
  }
  Thing topic FB2SS7_temp "FB2SS7_temp" (mqtt:broker:mosquitto) {
    Channels:
      Type number : FB2SS7_temp "State" [ stateTopic="tele/FB2-SS7/SENSOR", transformationPattern="JSONPATH:$.BMP280.Temperature" ]
  }
  Thing topic FB3SS20_temp "FB3SS20_temp" (mqtt:broker:mosquitto) {
    Channels:
      Type number : FB3SS20_temp "State" [ stateTopic="tele/FB3-SS20/SENSOR", transformationPattern="JSONPATH:$.BMP280.Temperature" ]
  }
  Thing topic GK1SS1_illuminance "GK1SS1_illuminance" (mqtt:broker:mosquitto) {
    Channels:
      Type number : GK1SS1_illuminance "State" [ stateTopic="tele/GK1-SS1/SENSOR", transformationPattern="JSONPATH:$.BH1750.Illuminance" ]
  }
  Thing topic GK1SS3_temp "GK1SS3_temp" (mqtt:broker:mosquitto) {
    Channels:
      Type number : GK1SS3_temp "State" [ stateTopic="tele/GK1-SS3/SENSOR", transformationPattern="JSONPATH:$.BMP280.Temperature" ]
  }
  Thing topic GL1NM1_temp "GL1NM1_temp" (mqtt:broker:mosquitto) {
    Channels:
      Type number : GL1NM1_temp "State" [ stateTopic="tele/GL1-NM1/temperature/value" ]
  }
  Thing topic GL1SS5_humid "GL1SS5_humid" (mqtt:broker:mosquitto) {
    Channels:
      Type number : GL1SS5_humid "State" [ stateTopic="tele/GL1-SS5/SENSOR", transformationPattern="JSONPATH:$.BME280.Humidity" ]
  }
  Thing topic GL1SS5_temp "GL1SS5_temp" (mqtt:broker:mosquitto) {
    Channels:
      Type number : GL1SS5_temp "State" [ stateTopic="tele/GL1-SS5/SENSOR", transformationPattern="JSONPATH:$.BME280.Temperature" ]
  }
  Thing topic GS1SS10_press "GS1SS10_press" (mqtt:broker:mosquitto) {
    Channels:
      Type number : GS1SS10_press "State" [ stateTopic="tele/GS1-SS10/SENSOR", transformationPattern="JSONPATH:$.BMP280.Pressure" ]
  }
  Thing topic GS1SS10_temp "GS1SS10_temp" (mqtt:broker:mosquitto) {
    Channels:
      Type number : GS1SS10_temp "State" [ stateTopic="tele/GS1-SS10/SENSOR", transformationPattern="JSONPATH:$.BMP280.Temperature" ]
  }
  Thing topic GY1NM2_temp1 "GY1NM2_temp1" (mqtt:broker:mosquitto) {
    Channels:
      Type number : GY1NM2_temp1 "State" [ stateTopic="tele/GY1-NM2/TT-02/value" ]
  }
  Thing topic GY1NM2_temp2 "GY1NM2_temp2" (mqtt:broker:mosquitto) {
    Channels:
      Type number : GY1NM2_temp2 "State" [ stateTopic="tele/GY1-NM2/TT-01/value" ]
  }
  Thing topic GY1SS22_distance "GY1SS22_distance" (mqtt:broker:mosquitto) {
    Channels:
      Type number : GY1SS22_distance "State" [ stateTopic="tele/GY1-SS22/SENSOR", transformationPattern="JSONPATH:$.VL53L0X.Distance" ]
  }
  Thing topic GY1SS24_humid "GY1SS24_humid" (mqtt:broker:mosquitto) {
    Channels:
      Type number : GY1SS24_humid "State" [ stateTopic="tele/GY1-SS24/SENSOR", transformationPattern="JSONPATH:$.BME280.Humidity" ]
  }
  Thing topic GY1SS24_press "GY1SS24_press" (mqtt:broker:mosquitto) {
    Channels:
      Type number : GY1SS24_press "State" [ stateTopic="tele/GY1-SS24/SENSOR", transformationPattern="JSONPATH:$.BME280.Pressure" ]
  }
  Thing topic GY1SS24_temp "GY1SS24_temp" (mqtt:broker:mosquitto) {
    Channels:
      Type number : GY1SS24_temp "State" [ stateTopic="tele/GY1-SS24/SENSOR", transformationPattern="JSONPATH:$.BME280.Temperature" ]
  }
  Thing topic GY1SS8_press "GY1SS8_press" (mqtt:broker:mosquitto) {
    Channels:
      Type number : GY1SS8_press "State" [ stateTopic="tele/GY1-SS8/SENSOR", transformationPattern="JSONPATH:$.BMP280.Pressure" ]
  }
  Thing topic GY1SS8_temp "GY1SS8_temp" (mqtt:broker:mosquitto) {
    Channels:
      Type number : GY1SS8_temp "State" [ stateTopic="tele/GY1-SS8/SENSOR", transformationPattern="JSONPATH:$.BMP280.Temperature" ]
  }
  Thing topic XM1SS16_temp "XM1SS16_temp" (mqtt:broker:mosquitto) {
    Channels:
      Type number : XM1SS16_temp "State" [ stateTopic="tele/XM1-SS16/SENSOR", transformationPattern="JSONPATH:$.DS18B20.Temperature" ]
  }

// -----------------------------
// STATUS11 (RSSI/Uptime) — with commandTopic so rules can send "11"
// -----------------------------
Thing topic FB1SS13_rssi (mqtt:broker:mosquitto) {
  Channels:
    Type number : state "State" [
      stateTopic="stat/FB1-SS13/STATUS11",
      transformationPattern="JSONPATH:$.StatusSTS.Wifi.RSSI",
      commandTopic="cmnd/FB1-SS13/status"
    ]
}
