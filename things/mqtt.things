// -----------------------------
// STATUS5 (IP) + Uptime (STATUS11) — IP uses its own channel id; Uptime uses :state
// -----------------------------
Thing topic FB1SS13_IPAddress (mqtt:broker:mosquitto) {
  Channels:
    Type string : FB1SS13_IPAddress "IP Address" [
      stateTopic="stat/FB1-SS13/STATUS5",
      transformationPattern="JSONPATH:$.StatusNET.IPAddress",
      commandTopic="cmnd/FB1-SS13/status"
    ]
}
Thing topic FB1SS13_Uptime (mqtt:broker:mosquitto) {
