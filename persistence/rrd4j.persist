Strategies {
    everyMinute : "0 * * * * ?"
}

Items {
    * : strategy = everyChange, restoreOnStartup
    gTemperature*, gOutside*, gBoiler*, gPressure*, gHumidity*, gPower* : strategy = everyMinute, everyChange, restoreOnStartup
    FB1SS6_gas, GY1SS28_moisture, GY1FT1_level_pc, GO1EM1_V, GO1EM1_I : strategy = everyMinute, everyChange, restoreOnStartup
}
