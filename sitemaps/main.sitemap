Frame label="Data" {
		Text label="Records" icon="temperature" {
			Frame label="Outside Temperature" {
				Text item=Temp_Today_Min_Time_Format 
				Text item=Temp_Today_Max_Time_Format
				Text item=Temp_Week_Min_Time_Format 
				Text item=Temp_Week_Max_Time_Format
				Text item=Temp_Month_Min_Time_Format 
				Text item=Temp_Month_Max_Time_Format
				Text item=Temp_Year_Min_Time_Format 
				Text item=Temp_Year_Max_Time_Format
				Text item=Temp_All_Min_Time_Format 
				Text item=Temp_All_Max_Time_Format
			}
		}

			Group item=gSetpoints label="Control" icon="settings"{
		    Frame label="SwitchBot" {
			Switch item=GK1SW04_switch label="Coffee Machine"
			}
		    Frame label="Menu" {
			Switch item=Christmas_Menu label="Christmas Menu"
			}			
		    Frame label="BlueIris" {
			Switch item=BlueIris_rearEnable label="Rear Motion Detection"
			Setpoint item=HueFrontTrigger_Setpoint label="Blue Iris Trigger Brightness [%.0f %%]" minValue=5.0 maxValue=100.0 step=5
			Setpoint item=HueFrontTrigger_Timer label="Blue Iris Trigger Timeout [%.0f sec]" minValue=5 maxValue=300 step=5
			Setpoint item=HueRearTrigger_Setpoint label="Rear Motion Brightness [%.0f %%]" minValue=5.0 maxValue=100.0 step=5
			Setpoint item=HueRearTrigger_Timer label="Blue Iris Trigger Timeout [%.0f sec]" minValue=5 maxValue=300 step=5
			}
			Frame label="Lighting Mode" {
			Switch item=Lighting_Mode label="Mode Override" mappings=[1="Evening", 2="Night", 4="Morning", 3="Off"]
			}
			Frame label="Motion Lights (Hall)" {
			Text item=Motion_Lights_Status label="Status"
			Setpoint item=Motion_Setpoint label="Brightness [%.0f %%]" minValue=10.0 maxValue=100.0 step=5
			Switch item=Motion_Lights label="Enable Status" mappings=[ON="ON", OFF="OFF"]
			Setpoint item=Motion_Time label="Timeout [%.1f min]" minValue=0.5 maxValue=30.0 step=0.5 // min 0.5 min to allow motion sensor to reset
			}
			Frame label="Dark Daytime Lights Front" {
			Setpoint item=Lux_Min_Hall label="Brightness Trigger [%.0f lx]" minValue=10 maxValue=200 step=2
			Setpoint item=Lux_Max_Hall label="Brightness Reset [%.0f lx]" minValue=20 maxValue=250 step=2
			//Setpoint item=Hall_Test_Lux label="Test Setpoint [%.0f lx]" minValue=20 maxValue=250 step=10
			Setpoint item=DarkHall_Setpoint label="Hall Brightness [%.0f %%]" minValue=10.0 maxValue=100.0 step=5
			}
			Frame label="Dark Daytime Lights Rear" {
			Setpoint item=Lux_Min_Kitchen label="Brightness Trigger [%.0f lx]" minValue=2 maxValue=200 step=2
			Setpoint item=Lux_Max_Kitchen label="Brightness Reset [%.0f lx]" minValue=2 maxValue=250 step=2
			Setpoint item=DarkKitchen_Setpoint label="Kitchen Brightness [%.0f %%]" minValue=5.0 maxValue=100.0 step=5
			//Setpoint item=Kitchen_Test_Lux label="Test Setpoint [%.0f lx]" minValue=0 maxValue=250 step=10
			}
			Frame label="Hall Schedule Setpoints" {
			Setpoint item=DarkMorning_Setpoint label="Dark Morning Brightness [%.0f %%]" minValue=10.0 maxValue=100.0 step=5
			Setpoint item=Dusk_Setpoint label="Dusk Brightness [%.0f %%]" minValue=10.0 maxValue=100.0 step=5
			Setpoint item=Evening_Setpoint label="Evening Brightness [%.0f %%]" minValue=10.0 maxValue=100.0 step=5
			Setpoint item=NightHallFront_Setpoint label="Night Front Brightness [%.0f %%]" minValue=0 maxValue=100.0 step=5
			Setpoint item=NightHallMid_Setpoint label="Night Mid Brightness [%.0f %%]" minValue=0 maxValue=100.0 step=5
			Setpoint item=NightHallRear_Setpoint label="Night Rear Brightness [%.0f %%]" minValue=0 maxValue=100.0 step=5
			}
			Frame label="Kitchen Schedule Setpoints" {
			Setpoint item=KitDusk_Setpoint label="Dusk Brightness [%.0f %%]" minValue=5.0 maxValue=100.0 step=5
			Setpoint item=KitEvening_Setpoint label="Evening Brightness [%.0f %%]" minValue=5.0 maxValue=100.0 step=5
			}
			Frame label="Front Outside Lights" {
			Setpoint item=HueFrontDarkMorning_Setpoint label="Dark Morning Brightness [%.0f %%]" minValue=5.0 maxValue=100.0 step=5
