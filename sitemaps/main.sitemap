sitemap main label="Main Menu"

{
	
Frame label="Dashboard" {
		Text item=GY1SS8_temp label="Outdoor Temperature"
		Text item=gTemperatureAvg 
		//Switch item=Lighting_Mode label="Lighting Override" mappings=[4="Morning", 3="Day", 1="Evening", 2="Night"]
		Text item=Light_Status label="Lighting Mode"
		Text item=GO1EM1_P label="Energy Meter [%.1f W]" {	
				Frame label="Live Data"{
				Text item=GO1EM1_V
				Text item=GO1EM1_I
				Text item=GO1EM1_P
				Text item=GO1EM1_Q
				Text item=GO1EM1_PF
				Text item=GO1EM1_F
				Text item=GO1EM1_TE
				Text item=GO1EM1_M
				Input item=GO1EM1_SetRead label="Correct Reading [%.1f kWh]"
				Text item=GO1EM1_Offset
				}

				Frame label="Consumption"{
				Text item=Power_Today
				Text item=Power_CostToday
				Text item=Power_Day 
				Text item=Power_Cost
				}

				Frame label="Current Tariff"{
				Text  item=Power_EUnit 
				Text  item=Power_EStand  
				Text  item=Power_GUnit 
				Text  item=Power_GStand 
				}

				Frame label="Voltage"{
				Switch item=Chart_Period label="Chart Period" icon="time" mappings=[0="Hour", 1="Day", 2="Week", 3="Month", 4="Year"]
				Chart item=GO1EM1_V period=h refresh=60000 visibility=[Chart_Period==0]
				Chart item=GO1EM1_V period=D refresh=60000 visibility=[Chart_Period==1]
				Chart item=GO1EM1_V period=W refresh=60000 visibility=[Chart_Period==2]
				Chart item=GO1EM1_V period=M refresh=60000 visibility=[Chart_Period==3]
				Chart item=GO1EM1_V period=Y refresh=60000 visibility=[Chart_Period==4]
				}

				Frame label="Current"{
				Switch item=Chart_Period label="Chart Period" icon="time" mappings=[0="Hour", 1="Day", 2="Week", 3="Month", 4="Year"]
				Chart item=GO1EM1_I period=h refresh=60000 visibility=[Chart_Period==0]
				Chart item=GO1EM1_I period=D refresh=60000 visibility=[Chart_Period==1]
				Chart item=GO1EM1_I period=W refresh=60000 visibility=[Chart_Period==2]
				Chart item=GO1EM1_I period=M refresh=60000 visibility=[Chart_Period==3]
				Chart item=GO1EM1_I period=Y refresh=60000 visibility=[Chart_Period==4]
				}

				Frame label="Power"{
				Switch item=Chart_Period label="Chart Period" icon="time" mappings=[0="Hour", 1="Day", 2="Week", 3="Month", 4="Year"]
				Chart item=gPower period=h refresh=60000 visibility=[Chart_Period==0]
				Chart item=gPower period=D refresh=60000 visibility=[Chart_Period==1]
				Chart item=gPower period=W refresh=60000 visibility=[Chart_Period==2]
				Chart item=gPower period=M refresh=60000 visibility=[Chart_Period==3]
				Chart item=gPower period=Y refresh=60000 visibility=[Chart_Period==4]
				}

				Frame label="Settings" icon="settings"
				{
					Text label="Tariff" icon="price"
					{
						Frame label="Electricity Unit" icon="price"{
							Setpoint  item=Power_EUnit label="Unit Price (x.00) [%.2f p/kWh]" minValue=20 maxValue=50 step=1
							Setpoint  item=Power_EUnit label="Unit Price (0.x0) [%.2f p/kWh]" minValue=20 maxValue=50 step=0.1 
							Setpoint  item=Power_EUnit label="Unit Price (0.0x) [%.2f p/kWh]" minValue=20 maxValue=50 step=0.01 	
						}
						Frame label="Electricity Standing" icon="price"{
							Setpoint  item=Power_EStand label="Standing Charge (x.00) [%.2f p/kWh]" minValue=30 maxValue=80 step=1
							Setpoint  item=Power_EStand label="Standing Charge (0.x0) [%.2f p/kWh]" minValue=30 maxValue=80 step=0.1 
							Setpoint  item=Power_EStand label="Standing Charge (0.0x) [%.2f p/kWh]" minValue=30 maxValue=80 step=0.01 	
						}
						Frame label="Gas Unit" icon="price"{
							Setpoint  item=Power_GUnit label="Unit Price (x.00) [%.2f p/kWh]" minValue=5 maxValue=15 step=1
							Setpoint  item=Power_GUnit label="Unit Price (0.x0) [%.2f p/kWh]" minValue=5 maxValue=15 step=0.1 
							Setpoint  item=Power_GUnit label="Unit Price (0.0x) [%.2f p/kWh]" minValue=5 maxValue=15 step=0.01 	
						}
						Frame label="Gas Standing" icon="price"{
							Setpoint  item=Power_GStand label="Standing Charge (x.00) [%.2f p/kWh]" minValue=20 maxValue=50 step=1
							Setpoint  item=Power_GStand label="Standing Charge (0.x0) [%.2f p/kWh]" minValue=20 maxValue=50 step=0.1 
							Setpoint  item=Power_GStand label="Standing Charge (0.0x) [%.2f p/kWh]" minValue=20 maxValue=50 step=0.01 	
						}			
					}
				}
		}
		Text item=gHeating label="Central Heating [%d zones active]" visibility=[hStandby == 0]
		Text item=hStandbyNumber label="Central Heating [%d zones active]" visibility=[hStandby == 1]
		Text item=hStatus label="Heating Mode"
		Switch item=GY1SS9_switch label="Gate Control" mappings=[ON="Open/Stop/Close"] 
		Switch item=gatePosition mappings=[1="Closed", 2="Moving", 4="In between", 3="Open"]
		//Text item=GO1EM1_voltage label="Mains Voltage"
		//Switch item=XM1DB1_doorbell label="Doorbell"

		Switch item=Presence_Override icon="settings" mappings=[ON="OVERRIDE", OFF="NORMAL"]
		//Text item=GY1MC1_temp label="Freezer PV [%.1f °C]"

		//Slider item=gHueDimmer label="Landing/Hall Dimmer"
		//Slider item=gHueKitchen label="Kitchen Dimmer"
		//Slider item=GH1HB1_dimmer label="Hue Hall"
		//Slider item=FL1HB2_dimmer label="Hue Landing Front"
		//Slider item=FL1HB3_dimmer label="Hue Landing Rear"
		/*Text item=GO1HT1_temperature label="Current Temperature"
		#Setpoint item=GO1HT1_setpoint label="Heating Setpoint" minValue=5.0 maxValue=30 step=0.5*/
		//Switch item=gPlugs mappings=[OFF="All Off", ON="All On"]
		//Switch item=gSonoff mappings=[OFF="All Off", ON="All On"]
		//Text  item=GY1SA4_smoke label="Smoke Detector Shed"
		//Text  item=FL1SA2_smoke label="Smoke Detector Landing"
		/*Switch item=GO1SP1_switch label="Plug Office"
		Switch item=GL1SP2_switch label="Plug Living Room"
		Switch item=FB1SP3_switch label="Plug Bedroom"*/
		/*Text  item=GK1SS1_temp label="Sonoff Temp."
		Text  item=GK1SS1_humid label="Sonoff RH"
		Text item=Scene label="Scene"*/
	}

	Frame label="Devices" {

		Text label="Central Heating" icon="radiator" {

			Frame label="System" 
			{
				Switch  item=GY1SS8_switch label="Call for Heat" mappings=[OFF="OFF", ON="ON"]
				//Switch item=gHeating label="Zones Active" mappings=[ON="None", OFF="1+"]
				Switch item=hMode label="Mode" mappings=[0="Manual", 1="Auto"]
				Switch item=GY1SS8_power label="Boiler Switch Feedback" mappings=[OFF="OFF", ON="ON"]
				Text item=gHeating label="Zones Active [%d]" visibility=[hStandby == 0]
				Text item=hStandbyNumber label="Zones Active [%d]" visibility=[hStandby == 1]
				Text item=hStatus label="Heating Mode"
				Text item=GY1NM2_temp1 label="Boiler Supply"
				Text item=GY1NM2_temp2 label="Boiler Return"
				Text item=GY1NM2_delta label="Boiler Delta"
				Text item=hRuntimeToday label="Boiler Runtime Today"
				//Text item=gHeatingFault label="Zones Faults [%s]"
			}

			Frame label="Room Temperatures"{
					Chart item=gTemperature period=d refresh=15000
			}

			Frame label="Boiler"{
					Chart item=gBoiler period=h refresh=15000 
			}

			Frame label="Radiator Status" {
				Switch  item=GO1SS12_switch mappings=[ON="OFF", OFF="ON"]
				Switch  item=GL1SS5_switch mappings=[ON="OFF", OFF="ON"]
				Switch  item=GS1SS10_switch mappings=[ON="OFF", OFF="ON"]
				Switch  item=GL1SS11_switch mappings=[ON="OFF", OFF="ON"]
				Switch  item=FB1SS13_switch1 mappings=[ON="OFF", OFF="ON"] 
				Switch  item=FB1SS13_switch2 mappings=[ON="OFF", OFF="ON"] 
				Switch  item=FB3SS19_switch mappings=[ON="OFF", OFF="ON"] 
			}
			Frame label="Temperature Control" {
				Text  item=GO1SS4_temp label="Office PV" 
				Setpoint  item=hSP_GO1 label="Office SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
				Text  item=GK1SS3_temp label="Kitchen PV"
				Setpoint  item=hSP_GK1 label="Kitchen SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
				Text  item=GL1SS5_temp label="Living Room PV"
				Setpoint  item=hSP_GL1 label="Living Room SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
				Text  item=GS1SS10_temp label="Sun Room PV"
				Setpoint  item=hSP_GS1 label="Sun Room SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
				Text  item=FB1SS6_temp label="Master Bedroom PV"
				Setpoint  item=hSP_FB1 label="Master Bedroom SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
				Text  item=FB2SS7_temp label="Workshop PV"
				Setpoint  item=hSP_FB2 label="Workshop SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
				Text  item=FB3SS20_temp label="Guest Bedroom PV"
				Setpoint  item=hSP_FB3 label="Guest Bedroom SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
			}

			Frame label="Temperature Deltas" {
				Text  item=GO1SS4_temp_delta label="Office dT" 
				Text  item=GK1SS3_temp_delta label="Kitchen dT"
				Text  item=GL1SS5_temp_delta label="Living Room dT"
				Text  item=GS1SS10_temp_delta label="Sun Room dT"
				Text  item=FB1SS6_temp_delta label="Master Bedroom dT"
				Text  item=FB2SS7_temp_delta label="Workshop dT"
				Text  item=FB3SS20_temp_delta label="Guest Bedroom dT"
				Text  item=gTemperatureDelta label="Temperature Min. dT [%.1f °C]"
			}

			Frame label="Settings"
				{
					Switch item=hAway label="Holiday"
					Switch item=hWork label="Home"
					Text label="Set Points" icon="Heating"
						{
							Frame label="Weekday Morning"
							{
								Setpoint  item=hSPm_GO1 label="Office SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=hSPm_GK1 label="Kitchen SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=hSPm_GL1 label="Living Room SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=hSPm_GS1 label="Sun Room SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=hSPm_FB1 label="Master Bedroom SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=hSPm_FB2 label="Workshop SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=hSPm_FB3 label="Guest Bedroom SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=gHeatingSP1 label="All Rooms SP [%.1f °C]" minValue=15 maxValue=25 step=1							
							}
							Frame label="Weekday Daytime"
							{
								Setpoint  item=hSPd_GO1 label="Office SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=hSPd_GK1 label="Kitchen SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=hSPd_GL1 label="Living Room SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=hSPd_GS1 label="Sun Room SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=hSPd_FB1 label="Master Bedroom SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=hSPd_FB2 label="Workshop SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=hSPd_FB3 label="Guest Bedroom SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=gHeatingSP2 label="All Rooms SP [%.1f °C]" minValue=15 maxValue=25 step=1								
							}
							Frame label="Weekend Morning & Daytime"
							{
								Setpoint  item=hSPw_GO1 label="Office SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=hSPw_GK1 label="Kitchen SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=hSPw_GL1 label="Living Room SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=hSPw_GS1 label="Sun Room SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=hSPw_FB1 label="Master Bedroom SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=hSPw_FB2 label="Workshop SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=hSPw_FB3 label="Guest Bedroom SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=gHeatingSP5 label="All Rooms SP [%.1f °C]" minValue=15 maxValue=25 step=1								
							}
							Frame label="Evening"
							{
								Setpoint  item=hSPe_GO1 label="Office SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=hSPe_GK1 label="Kitchen SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=hSPe_GL1 label="Living Room SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=hSPe_GS1 label="Sun Room SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=hSPe_FB1 label="Master Bedroom SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=hSPe_FB2 label="Workshop SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=hSPe_FB3 label="Guest Bedroom SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=gHeatingSP3 label="All Rooms SP [%.1f °C]" minValue=15 maxValue=25 step=1								
							}
							Frame label="Night"
							{
								Setpoint  item=hSPn_GO1 label="Office SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=hSPn_GK1 label="Kitchen SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=hSPn_GL1 label="Living Room SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=hSPn_GS1 label="Sun Room SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=hSPn_FB1 label="Master Bedroom SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=hSPn_FB2 label="Workshop SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=hSPn_FB3 label="Guest Bedroom SP [%.1f °C]" minValue=15 maxValue=25 step=0.1
								Setpoint  item=gHeatingSP4 label="All Rooms SP [%.1f °C]" minValue=15 maxValue=25 step=1								
							}
							Frame label="Holiday"
							{
								Setpoint  item=hSPh_GO1 label="Office SP [%.1f °C]" minValue=13 maxValue=25 step=0.1
								Setpoint  item=hSPh_GK1 label="Kitchen SP [%.1f °C]" minValue=13 maxValue=25 step=0.1
								Setpoint  item=hSPh_GL1 label="Living Room SP [%.1f °C]" minValue=13 maxValue=25 step=0.1
								Setpoint  item=hSPh_GS1 label="Sun Room SP [%.1f °C]" minValue=13 maxValue=25 step=0.1
								Setpoint  item=hSPh_FB1 label="Master Bedroom SP [%.1f °C]" minValue=13 maxValue=25 step=0.1
								Setpoint  item=hSPh_FB2 label="Workshop SP [%.1f °C]" minValue=13 maxValue=25 step=0.1
								Setpoint  item=hSPh_FB3 label="Guest Bedroom SP [%.1f °C]" minValue=13 maxValue=25 step=0.1
								Setpoint  item=gHeatingSP6 label="All Rooms SP [%.1f °C]" minValue=15 maxValue=25 step=1								
							}
							Frame label="Global Override"
							{
								Setpoint  item=gHeatingSP label="SP [%.1f °C]" minValue=15 maxValue=25 step=1
							}
						}						
					Text label="Boiler" icon="fire"
					{
						Frame label="Boiler Run Time"
						{
							Text item=hRuntimeToday label="Today [%.0f min]" 
							Text item=hRuntimeYesterday label="Yesterday [%.0f min]" 
							Text item=hRuntimeThisWeek label="This Week [%.1f hr]" 
							Text item=hRuntimeLastWeek label="Last Week [%.1f hr]" 
							Text item=hRuntimeThisMonth label="This Month [%.1f hr]" 
							Text item=hRuntimeLastMonth label="Last Month [%.1f hr]" 
						}
					}	

					Text label="Advanced" icon="settings"
					{
						Frame label="General"
						{
							Setpoint  item=hHysteresis label="Hysteresis [± %.1f °C]" minValue=0.1 maxValue=2 step=0.1
							Switch item=hOverride label="Mode Override" mappings=[1="Weekday morning", 2="Weekday daytime", 3="Evening", 4="Night", 5="Weekend morning/daytime"]
						}
						Frame label="Radiator Override" 
						{
							Switch  item=hGO1_Radiator mappings=[0="Disable", 1="Enable"]
							Switch  item=hGL1_Radiator mappings=[0="Disable", 1="Enable"]
							Switch  item=hGK1_Radiator mappings=[0="Disable", 1="Enable"]
							Switch  item=hGS1_Radiator mappings=[0="Disable", 1="Enable"]
							Switch  item=hFB1_Radiator mappings=[0="Disable", 1="Enable"]
							Switch  item=hFB2_Radiator mappings=[0="Disable", 1="Enable"]
							Switch  item=hFB3_Radiator mappings=[0="Disable", 1="Enable"]
							Setpoint  item=hStandby label="Standby Variable [%.0f]" minValue=0 maxValue=1 step=1
						}
					}	


				}

		
		}

		Text label="Sonos" icon="rollershutter" {

    Frame label="Whole House" {
        Switch item=Sonos_All_PlayPause mappings=[ON="Play/Pause All"]
        Switch item=Sonos_All_Next      mappings=[ON="Next ▶▶"]
        Switch item=Sonos_All_Prev      mappings=[ON="⏮ Prev"]
        Switch item=Sonos_All_Mute      mappings=[ON="Mute All"]
        Switch item=Sonos_All_Unmute    mappings=[ON="Unmute All"]
        Switch item=Sonos_All_VolUp     mappings=[ON="Vol +"]
        Switch item=Sonos_All_VolDown   mappings=[ON="Vol -"]

        // optional: see who we think is the current master
        Text   item=Sonos_CurrentMaster label="Group Master [%s]"
    }

    Frame label="Presets" {
        Switch item=Sonos_Preset_BBCR2        mappings=[ON="Start", OFF="Stop"]
        Slider item=Sonos_Preset_BBCR2_Volume label="Volume"
    }

    Frame label="Living Room – Connect:Amp" {
        Text   item=Sonos_LivingRoom_CurrentTrack label="Now Playing [%s]"
        Slider item=Sonos_LivingRoom_Volume       label="Volume"
        Switch item=Sonos_LivingRoom_Mute         label="Mute" mappings=[ON="Mute", OFF="Unmute"]

        Switch item=Sonos_LivingRoom_Control mappings=[PLAY="▶ Play"]
