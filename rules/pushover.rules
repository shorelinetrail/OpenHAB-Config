rule "BBQ Temperature"
        when
                Time cron "0 0/20 * 1/1 * ? *"
        then

            if(remoteTempEnable.state == ON){
                pushover.apply("BBQ Temperature: " + GL1NM1_temp.state + " °C")
            }

        end

