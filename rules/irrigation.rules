// --- Pushover (OH5 binding) reusable lambda (null-guarded: log + return if offline) ---
val org.eclipse.xtext.xbase.lib.Functions$Function1<String, Boolean> pushover = [ String message |
    val actions = getActions("pushover", "pushover:pushover-account:account")
    if (actions === null) {
        logWarn("pushover", "Pushover offline - message dropped: " + message)
        false
    } else {
        actions.sendMessage(message)
    }
]

// High-priority variant (priority 1: bypasses quiet hours, no ack loop) for the
// overflow-risk alert.
val org.eclipse.xtext.xbase.lib.Functions$Function1<String, Boolean> pushoverHigh = [ String message |
    val actions = getActions("pushover", "pushover:pushover-account:account")
    if (actions === null) {
        logWarn("pushover", "Pushover offline - high-priority dropped: " + message)
        false
    } else {
        actions.sendPriorityMessage(message, "Water Butt", 1)
        true
    }
]

var Number front_flow_T = 0
var Timer timerFront = null
var Timer timerFront1 = null
var Number totalStart = 0

var Number rear_flow_T = 0
var Timer timerRear = null
var Timer timerRear1 = null
var Number totalStart_R = 0
var Timer timerButtRefill = null
var Timer timerRearStart = null
var Timer timerDrainCheck = null
var boolean drainNoFlowAlerted = false

rule "Front Irrigation Control"
    when
            Item Iri_F_Switch changed 
    then
        if(Iri_F_Switch.state == 1){
            sendCommand(Iri_F_Total, 0)
            sendCommand(GY1SS26_switch, ON)
            timerFront = createTimer(now.plusSeconds(30), [ |
            timerFront = null
            totalStart = 1
            val Number flow = (GY1SS27_flow.state as Number/2)
                if (flow > 0) {
                    Iri_F_Total.sendCommand(flow)
                } else {
                    Iri_F_Switch.sendCommand(2)
                    pushover.apply("No front irrigation flow, cancelled.")
                }
            ])
        }
        else if(Iri_F_Switch.state == 2)
        {
            sendCommand(GY1SS26_switch, OFF)
            totalStart = 0
        }
end

rule "Front Irrigation Totaliser"
    when
            Time cron "0/10 * * * * ?"
    then
        if(totalStart == 1){
            front_flow_T = Iri_F_Total.state as Number + (GY1SS27_flow.state as Number/6)
            sendCommand(Iri_F_Total, front_flow_T)
            }
end

rule "Front Irrigation Stop"
    when
            Item Iri_F_Total changed 
    then
        if(Iri_F_Total.state as Number >= Iri_F_SP.state as Number){
            sendCommand(Iri_F_Switch, 2)
            pushover.apply("Front irrigation complete.")
            }
end

rule "Water Butt Level"
    when
            Item GY1FT1_level changed
    then
        // Robustness: ignore NULL/UNDEF (sensor dropout / pre-restore) so the overflow
        // protection never runs on a bad reading and never aborts half-way.
        if (!(GY1FT1_level.state instanceof Number)) {
            logWarn("irrigation", "Water Butt Level: GY1FT1_level=" + GY1FT1_level.state + " (not a number) - skipping")
            return;
        }

        val Number raw = GY1FT1_level.state as Number
        // Decide on THIS reading. The old rule compared GY1FT1_level_pc.state right
        // after sendCommand-ing it, i.e. against the PREVIOUS value (async update).
        val Number pc = (raw * 0.1283) - 8.7262

        GY1FT1_level_mm.postUpdate ((raw * 0.9775) - 66.5)
        GY1FT1_level_pc.postUpdate (pc)
        GY1FT1_level_vol.postUpdate((raw * 0.1058) - 6.6877)

        // Top-up valve: close (ON) once near full.
        if (pc > 90 && GY1FT1_switch3.state != ON) {
            GY1FT1_switch3.sendCommand(ON)
        }

        // Drain valve is fail-safe: OFF = OPEN (draining), ON = CLOSED (retaining).
        if (pc > 95) {
            // Open the drain to dump rain overflow. "!= OFF" so an unknown relay state
            // still drives it open (the old "== ON" guard skipped opening when NULL).
            if (GY1FT1_switch2.state != OFF) {
                GY1FT1_switch2.sendCommand(OFF)
                logInfo("irrigation", "Water butt " + String::format("%.1f%%", pc.doubleValue) + " - opening drain valve")
            }
            // Verify it actually drains: a blocked/stuck drain at >95% means imminent
            // overflow. Check the drain flow ~30s later; retry the open and alert once
            // if there is still no flow while still over the threshold.
            if (timerDrainCheck === null) {
                timerDrainCheck = createTimer(now.plusSeconds(30), [ |
                    timerDrainCheck = null
                    val boolean stillFull = (GY1FT1_level.state instanceof Number) &&
                                            (((GY1FT1_level.state as Number) * 0.1283 - 8.7262) > 95)
                    val boolean draining  = (GY1FT1_flow3.state instanceof Number) &&
                                            ((GY1FT1_flow3.state as Number) > 0.2)
                    if (stillFull && !draining) {
                        GY1FT1_switch2.sendCommand(OFF)   // retry in case the command was lost
                        if (!drainNoFlowAlerted) {
                            drainNoFlowAlerted = true
                            pushoverHigh.apply("Water butt full & not draining")
                        }
                    }
                ])
            }
        }

        // Drain valve: close (ON) once the level has fallen back into band.
        if (pc <= 90 && GY1FT1_switch2.state != ON) {
            timerButtRefill?.cancel
            timerButtRefill = createTimer(now.plusSeconds(3), [ |
                timerButtRefill = null
                if ((GY1FT1_level.state instanceof Number) &&
                    (((GY1FT1_level.state as Number) * 0.1283 - 8.7262) <= 90) &&
                    GY1FT1_switch2.state != ON) {
                    GY1FT1_switch2.sendCommand(ON)
                }
            ])
            // Recovered: clear the no-flow latch and any pending drain check.
            drainNoFlowAlerted = false
            timerDrainCheck?.cancel
            timerDrainCheck = null
        }
end


rule "Rear Irrigation Control"
    when
            Item Iri_F_Switch_R changed 
    then
        if(Iri_F_Switch_R.state == 1){
            sendCommand(Iri_F_Total_R, 0)
            sendCommand(GY1FT1_switch2, OFF)
            // 2.5s between closing switch2 and switch1 (non-blocking), then the
            // existing 30s flow-check timer.
            timerRearStart = createTimer(now.plusSeconds(3), [ |
                timerRearStart = null
                sendCommand(GY1FT1_switch1, OFF)
                timerRear = createTimer(now.plusSeconds(30), [ |
                    timerRear = null
                    totalStart_R = 1
                    val Number flow_R = (GY1FT1_flow3.state as Number/2)
                    if (flow_R > 0) {
                        Iri_F_Total_R.sendCommand(flow_R)
                    } else {
                        Iri_F_Switch_R.sendCommand(2)
                        pushover.apply("No rear irrigation flow, cancelled.")
                    }
                ])
            ])
        }
        else if(Iri_F_Switch_R.state == 2)
        {
            sendCommand(GY1FT1_switch1, ON)
            totalStart_R = 0
        }
end

rule "Rear Irrigation Totaliser"
    when
            Time cron "0/10 * * * * ?"
    then
        if(totalStart_R == 1){
            rear_flow_T = Iri_F_Total_R.state as Number + (GY1FT1_flow3.state as Number/6)
            sendCommand(Iri_F_Total_R, rear_flow_T)
            }
end

rule "Rear Irrigation Stop"
    when
            Item Iri_F_Total_R changed 
    then
        if(Iri_F_Total_R.state as Number >= Iri_F_SP_R.state as Number){
            sendCommand(Iri_F_Switch_R, 2)
            pushover.apply("Rear irrigation complete.")
            }
end