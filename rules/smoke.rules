// SMOKE DETECTION
//
//   GK1SA1_* = Kitchen  Fibaro FGSD002  (zwave:device:a76def7407:GK1-SA1)
//   FL1SA2_* = Landing   Fibaro FGSD002  (zwave:device:a76def7407:FL1-SA2)
//   GY1SA4_* = Shed      Tasmota / MQTT  (separate, legacy)
//
// All detector alarm Items share 0 = Alarm, 1 = OK. gSmokeAlarm holds them: the 10
// Fibaro alarm_* (smoke/heat/tamper/fault/battalarm) + shed GY1SA4_smoke/_tamper.

import org.openhab.core.library.types.DateTimeType

// --- Pushover (OH5 binding) reusable lambdas: (message, title), null-guarded ---
val org.eclipse.xtext.xbase.lib.Functions$Function2<String, String, Boolean> pushover = [ String message, String title |
    val actions = getActions("pushover", "pushover:pushover-account:account")
    if (actions === null) {
        logWarn("pushover", "Pushover offline - message dropped: " + title + " / " + message)
        false
    } else {
        actions.sendMessage(message, title)
    }
]
val org.eclipse.xtext.xbase.lib.Functions$Function2<String, String, String> pushoverEmergency = [ String message, String title |
    val actions = getActions("pushover", "pushover:pushover-account:account")
    if (actions === null) {
        logWarn("pushover", "Pushover offline - emergency dropped: " + title + " / " + message)
        null
    } else {
        actions.sendPriorityMessage(message, title, 2)
    }
]
val org.eclipse.xtext.xbase.lib.Functions$Function1<String, Boolean> cancelPushoverEmergency = [ String receipt |
    val actions = getActions("pushover", "pushover:pushover-account:account")
    if (actions === null) {
        logWarn("pushover", "Pushover offline - cannot cancel emergency: " + receipt)
        false
    } else {
        actions.cancelPriorityMessage(receipt)
    }
]

// Receipts for in-flight priority-2 (emergency) alerts, keyed by Item name, so a
// smoke/heat alarm that clears can cancel its own ack/retry loop. In-memory only:
// an openHAB restart between alarm and clear falls back to manual ack / expire.
val java.util.concurrent.ConcurrentHashMap<String, String> emergencyReceipts = new java.util.concurrent.ConcurrentHashMap()


rule "Update Last MQTT message timestamp"
when
    Item GY1SA4_online received update
then
    GY1SA4_LastUpdate.postUpdate(now.toString) // ISO string avoids type ambiguity
end


// Stamp last-seen on a real device report (temp/battery wakeup). Split per detector
// (rather than one rule keyed on triggeringItem) because triggeringItem is not
// reliably populated for `received update` triggers. Alarm Items are excluded so the
// System-started seeding doesn't fake a "last update".
rule "Kitchen Smoke Detector Last Update"
when
    Item GK1SA1_temp received update or
    Item GK1SA1_battpc received update
then
    GK1SA1_LastUpdate.postUpdate(now.toString)
end


rule "Landing Smoke Detector Last Update"
when
    Item FL1SA2_temp received update or
    Item FL1SA2_battpc received update
then
    FL1SA2_LastUpdate.postUpdate(now.toString)
end


rule "Smoke Detector Alarm Init"
when
    System started
then
    // Z-Wave alarm channels report only on a state change, so a freshly-linked Item
    // sits at NULL ("Unknown"). Seed the unreported ones to their OK value; a real
    // alarm overrides it. NB the OK value is source-dependent (see below).
    gSmokeAlarm.members.filter[ m | m.state == NULL || m.state == UNDEF ].forEach[ m |
        // OK-seed differs by source: Fibaro (Z-Wave, Switch ON=alarm -> Number) OK=0;
        // Shed (GY1SA4, MQTT) OK=1. Seeding the wrong value would fake an alarm.
        if (m.name.startsWith("GK1SA1") || m.name.startsWith("FL1SA2")) {
            m.postUpdate("0")
        } else {
            m.postUpdate("1")
        }
    ]
end


rule "Smoke Detector Alarm"
when
    Member of gSmokeAlarm changed
then
    val item = triggeringItem
    val ns = item.state
    if (!(ns instanceof Number)) {
        return;   // NULL/UNDEF transition (e.g. startup seeding) - nothing to alert
    }
    val name = item.name
    val location = if (name.startsWith("GK1SA1")) "Kitchen"
                   else if (name.startsWith("FL1SA2")) "Landing"
                   else if (name.startsWith("GY1SA4")) "Shed"
                   else name
    var String body    = "Alarm"               // active-alarm body wording
    var String cleared = "Alarm cleared"        // recovery body wording
    var boolean lifeSafety = false
    if      (name.endsWith("_smoke"))     { body = "SMOKE DETECTED"; cleared = "Smoke cleared";         lifeSafety = true }
    else if (name.endsWith("_heat"))      { body = "HEAT DETECTED";  cleared = "Heat cleared";          lifeSafety = true }
    else if (name.endsWith("_tamper"))    { body = "Tamper alarm";   cleared = "Tamper cleared" }
    else if (name.endsWith("_fault"))     { body = "System fault";   cleared = "System fault cleared" }
    else if (name.endsWith("_battalarm")) { body = "Low battery";    cleared = "Battery OK" }

    val title = location + " Smoke Detector"

    // Polarity differs by source. Fibaro (Z-Wave) alarm channels are Switch (ON=alarm),
    // surfaced on these Number Items as 1=Alarm / 0=OK. The Shed (GY1SA4, MQTT) uses the
    // opposite convention 0=Alarm / 1=OK. Normalise to a per-source boolean.
    val isFibaro = name.startsWith("GK1SA1") || name.startsWith("FL1SA2")
    val cur = (ns as Number).intValue
    val alarmNow  = if (isFibaro) (cur != 0) else (cur == 0)
    val prevAlarm = if (previousState instanceof Number) {
                        val p = (previousState as Number).intValue
                        if (isFibaro) (p != 0) else (p == 0)
                    } else false

    if (alarmNow) {
        // alarm active
        logWarn("smoke.rules", title + ": " + body)
        if (lifeSafety) {
            val receipt = pushoverEmergency.apply(body, "🔥 " + title)   // priority 2 - requires acknowledgement
            if (receipt !== null) {
                emergencyReceipts.put(name, receipt)            // remember it so recovery can cancel the nag
            }
        } else {
            pushover.apply(body, "🔥 " + title)
        }
    } else if (prevAlarm) {
        // cleared from an active alarm: cancel any outstanding emergency, then confirm
        val receipt = emergencyReceipts.remove(name)
        if (receipt !== null) {
            cancelPushoverEmergency.apply(receipt)
        }
        pushover.apply("✅ " + cleared, title)
    }
end


rule "Smoke Detector Battery Low"
when
    Item GK1SA1_battpc changed or
    Item FL1SA2_battpc changed or
    Item GY1SA4_battpc changed
then
    val item = triggeringItem
    if (!(item.state instanceof Number)) {
        return;
    }
    val pc   = (item.state as Number).intValue
    val prev = if (previousState instanceof Number) (previousState as Number).intValue else 999
    if (pc < 20 && prev >= 20) {            // alert once, on crossing below 20 %
        val location = if (item.name.startsWith("GK1SA1")) "Kitchen"
                       else if (item.name.startsWith("FL1SA2")) "Landing"
                       else "Shed"
        pushover.apply("Battery low (" + pc + "%)", "🔥 " + location + " Smoke Detector")
    }
end


rule "Smoke Detector Liveness"
when
    Time cron "0 7 0/6 * * ?"               // 00:07, 06:07, 12:07, 18:07
then
    // Z-Wave nodes that stop responding are marked OFFLINE/UNINITIALIZED. A
    // detector that never reports would otherwise sit on its seeded "OK", so
    // re-check status periodically and nag while a node is not ONLINE.
    val detectors = newLinkedHashMap(
        "zwave:device:a76def7407:GK1-SA1" -> "Kitchen",
        "zwave:device:a76def7407:FL1-SA2" -> "Landing"
    )
    detectors.forEach[ uid, loc |
        val info = getThingStatusInfo(uid)
        val status = if (info === null) "UNINITIALIZED" else info.getStatus.toString
        if (status != "ONLINE") {
            pushover.apply("Offline - Z-Wave node not responding (" + status + ")", "🔥 " + loc + " Smoke Detector")
        }
    ]

    // Shed (MQTT): no Z-Wave Thing - use the GY1SA4 heartbeat (GY1SA4_LastUpdate is
    // stamped on each GY1-SA4/connected message). Alert if no heartbeat for >2 h.
    // Tune the threshold to ~3x the device's actual publish interval.
    val lastSeen = GY1SA4_LastUpdate.state
    if (!(lastSeen instanceof DateTimeType)) {
        pushover.apply("Offline - no MQTT heartbeat received", "🔥 Shed Smoke Detector")
    } else if ((lastSeen as DateTimeType).getInstant.isBefore(now.minusHours(2).toInstant)) {
        pushover.apply("Offline - no MQTT heartbeat for over 2 hours", "🔥 Shed Smoke Detector")
    }
end
