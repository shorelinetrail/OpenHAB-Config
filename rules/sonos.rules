// ========================================
// PRESETS  (ON = start, OFF = stop)
// Groups a fixed room set under one coordinator, sets volume, plays a saved
// station. Stop pauses the group but leaves it grouped.
// ========================================

rule "Sonos Preset BBC Radio 2"
when
    Item Sonos_Preset_BBCR2 received command
then
    val String KITCHEN = "RINCON_B8E93733144401400"   // coordinator UDN (Kitchen PLAY:3)

    if (receivedCommand == ON) {
        Sonos_Kitchen_Standalone.sendCommand(ON)               // Kitchen = lone coordinator
        timerPresetR2a?.cancel
        timerPresetR2a = createTimer(now.plusSeconds(2), [ |
            timerPresetR2a = null
            Sonos_Office_Add.sendCommand(KITCHEN)              // others join Kitchen's group
            Sonos_SunRoom_Add.sendCommand(KITCHEN)
            Sonos_Bedroom_Add.sendCommand(KITCHEN)
            timerPresetR2b?.cancel
            timerPresetR2b = createTimer(now.plusSeconds(2), [ |
                timerPresetR2b = null
                val Number vol = if (Sonos_Preset_BBCR2_Volume.state instanceof Number) Sonos_Preset_BBCR2_Volume.state as Number else 25
                Sonos_Kitchen_Volume.sendCommand(vol)
                Sonos_Office_Volume.sendCommand(vol)
                Sonos_SunRoom_Volume.sendCommand(vol)
                Sonos_Bedroom_Volume.sendCommand(vol)
                Sonos_Kitchen_Radio.sendCommand("BBC Radio 2") // play on coordinator -> whole group
                Sonos_Kitchen_Control.sendCommand(PLAY)
            ])
        ])
    } else if (receivedCommand == OFF) {
        Sonos_Kitchen_Control.sendCommand(PAUSE)               // pause the group (stays grouped)
    }
end

rule "Sonos Preset BBC Radio 2 Volume"
when
    Item Sonos_Preset_BBCR2_Volume changed
then
    // Live-adjust the grouped rooms only while the preset is active.
    if (Sonos_Preset_BBCR2.state != ON) return;
    if (!(Sonos_Preset_BBCR2_Volume.state instanceof Number)) return;
    val Number vol = Sonos_Preset_BBCR2_Volume.state as Number
    Sonos_Kitchen_Volume.sendCommand(vol)
    Sonos_Office_Volume.sendCommand(vol)
    Sonos_SunRoom_Volume.sendCommand(vol)
    Sonos_Bedroom_Volume.sendCommand(vol)
end
