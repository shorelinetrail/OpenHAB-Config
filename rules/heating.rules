// Sensor Faults
rule "Sensor Office"
        when
                Item GO1SS4_temp changed
        then
                if((GO1SS4_temp.state > 40)||(GO1SS4_temp.state < 10)){
                        publish("mosquitto", "cmnd/GO1-SS4/restart", "1")
                        timerSonoffReset = createTimer(now.plusMinutes(2), [ |
                                if((GO1SS4_temp.state > 40)||(GO1SS4_temp.state < 2))
                                {
                                        timerSonoffReset = null
                                        sendCommand(hGO1_Radiator, 0)
                                        sendPushoverMessage(pushoverBuilder("GO1-SS4 temperature bad"))
                                }
                        ])
                }
        end

rule "Sensor Living Room"
        when
                Item GL1SS5_temp changed
        then
                if((GL1SS5_temp.state > 40)||(GL1SS5_temp.state < 10)){
                        publish("mosquitto", "cmnd/GL1-SS5/restart", "1")
                        timerSonoffReset = createTimer(now.plusMinutes(2), [ |
                                if((GL1SS5_temp.state > 40)||(GL1SS5_temp.state < 2))
                                {
                                        timerSonoffReset = null
                                        sendCommand(hGL1_Radiator, 0)
                                        sendPushoverMessage(pushoverBuilder("GL1-SS5 temperature bad"))
                                }
                        ])
                }
        end

