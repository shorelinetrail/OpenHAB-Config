rule "Sensor Guest Bedroom"
        when
                Item FB3SS20_temp changed
        then
                if((FB3SS20_temp.state > 40)||(FB3SS20_temp.state < 10)){
                        publish("mosquitto", "cmnd/FB3-SS20/restart", "1")
                        timerSonoffReset = createTimer(now.plusMinutes(2), [ |
                                if((FB3SS20_temp.state > 40)||(FB3SS20_temp.state < 2))
                                {
                                        timerSonoffReset = null
                                        sendCommand(hFB3_Radiator, 0)
                                        sendPushoverMessage(pushoverBuilder("FB3-SS20 temperature bad"))
                                }
                        ])
                }
        end

rule "Sensor Kitchen"
        when
                Item GK1SS3_temp changed
        then
                if((GK1SS3_temp.state > 40)||(GK1SS3_temp.state < 10)){
                        publish("mosquitto", "cmnd/GK1-SS3/restart", "1")
