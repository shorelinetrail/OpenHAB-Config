rule "Master Bedroom"
    when 
            Item FB1SS6_temp changed 
            or
            Item hSP_FB1 changed
            or
            Item hMode changed to 1
            or
            Item hFB1_Radiator changed
    then 
            //Switch ON
            if (((FB1SS6_temp.state as Number) <= ((hSP_FB1.state as Number) - (hHysteresis.state as Number))) && (hStandby.state == 0) && (FB1SS13_switch1.state == ON) && (hMode.state == 1) && (hFB1_Radiator.state == 1)) {
                    sendCommand (FB1SS13_switch1, OFF)
            }
            //Switch OFF
            else if ((((FB1SS6_temp.state as Number) >= ((hSP_FB1.state as Number) + (hHysteresis.state as Number))) && (FB1SS13_switch1.state == OFF) && (hMode.state == 1)) || (hFB1_Radiator.state == 0)) {
                    if(hStandby.state == 0 || ((FB1SS6_temp_delta.state as Number + hHysteresis.state as Number) < 0))
                    {
                        sendCommand (FB1SS13_switch1, ON)
                    }
            }
    end

