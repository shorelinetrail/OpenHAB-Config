rule "Heating Deltas"
    when 
            Time cron "0 0/10 * 1/1 * ? *"
            or
            Item gHeatingSP changed
    then 
            sendCommand(GO1SS4_temp_delta, (GO1SS4_temp.state as Number) - (hSP_GO1.state as Number))
            sendCommand(GK1SS3_temp_delta, (GK1SS3_temp.state as Number) - (hSP_GK1.state as Number))
            sendCommand(GL1SS5_temp_delta, (GL1SS5_temp.state as Number) - (hSP_GL1.state as Number))
            sendCommand(GS1SS10_temp_delta, (GS1SS10_temp.state as Number) - (hSP_GS1.state as Number))
            sendCommand(FB1SS6_temp_delta, (FB1SS6_temp.state as Number) - (hSP_FB1.state as Number))
            sendCommand(FB2SS7_temp_delta, (FB2SS7_temp.state as Number) - (hSP_FB2.state as Number))
            sendCommand(FB3SS20_temp_delta, (FB3SS20_temp.state as Number) - (hSP_FB3.state as Number))
    end

rule "Heating Relax"
    when 
            Time cron "0 0/10 * 1/1 * ? *"
            or
            Item gHeatingSP changed
    then 
            sendCommand(hStandbyNumber, 0)
            //Enable Standby
            if((GY1SS8_temp.state > 25)||(gTemperatureDelta.state > 1.5 && gTemperatureDelta.state < 20 && (hMode.state == 1) && GY1SS8_switch.state == OFF && hStandby.state == 0))
            {
                sendCommand(gHeating, OFF)
                sendCommand(hStandby, 1)
            }
            //Disable
            else if(gTemperatureDelta.state < 1 && GY1SS8_switch.state == OFF && hStandby.state == 1)
            {
                sendCommand(gHeating, ON)
                sendCommand(hStandby, 0)
            }
    end

rule "Heating ON"
    when
            Item gHeating changed to OFF
    then
                timerHeating = createTimer(now.plusMinutes(6), [ |     // delay to allow thermal actuator to open
                if((hMode.state == 1) && (gHeating.state == OFF) && (hStandby.state == 0)){
                sendCommand(GY1SS8_switch, ON)
                Thread::sleep(20000)
                if(GY1SS8_power.state == "ON"){
                        logInfo("heating.rules", "Boiler call for heat success")
                }
                if(GY1SS8_power.state == "OFF" && GY1SS8_switch.state == ON){
                        logInfo("heating.rules", "Boiler call for heat failed, retrying...")
                        sendCommand(GY1SS8_switch, ON)
                        Thread::sleep(20000)
                        if(GY1SS8_power.state == "ON"){
                                logInfo("heating.rules", "Boiler call for heat success")
                        }
                        if(GY1SS8_power.state == "OFF" && GY1SS8_switch.state == ON){
                                logInfo("heating.rules", "Boiler call for heat failed, retrying...")
                                sendCommand(GY1SS8_switch, ON)
                                Thread::sleep(20000)
                                if(GY1SS8_power.state == "ON"){
                                        logInfo("heating.rules", "Boiler call for heat success")
                                }
                                if(GY1SS8_power.state == "OFF" && GY1SS8_switch.state == ON){
                                        logInfo("heating.rules", "Boiler call for heat failed")
                                        sendPushoverMessage(pushoverBuilder("Boiler call for heat failed").withEmergencyPriority())
                                }                      
                        }
                }
                timerHeating = null       
                }
                ])
end

rule "Heating OFF"
    when
            Item gHeating changed to ON
    then
            if(hMode.state == 1 && hStandby.state == 0){
                sendCommand(GY1SS8_switch, OFF)
                Thread::sleep(20000)
                if(GY1SS8_power.state == "OFF"){
                        logInfo("heating.rules", "Boiler switched off")
                }
                if(GY1SS8_power.state == "ON" && GY1SS8_switch.state == OFF){
                        logInfo("heating.rules", "Boiler failed to switch off, retrying...")
                        sendCommand(GY1SS8_switch, OFF)
                        Thread::sleep(20000)
                        if(GY1SS8_power.state == "OFF"){
                                logInfo("heating.rules", "Boiler switched off")
                        }
                        if(GY1SS8_power.state == "ON" && GY1SS8_switch.state == OFF){
                                logInfo("heating.rules", "Boiler failed to switch off, retrying...")
                                sendCommand(GY1SS8_switch, OFF)
                                Thread::sleep(20000)
                                if(GY1SS8_power.state == "OFF"){
                                        logInfo("heating.rules", "Boiler switched off")
                                }
                                if(GY1SS8_power.state == "ON" && GY1SS8_switch.state == OFF){
                                        logInfo("heating.rules", "Boiler failed to switch off")
                                        sendPushoverMessage(pushoverBuilder("Boiler failed to switch off").withEmergencyPriority())
                                }                      
                        }
                }
                timerHeating = null
            }
    end

rule "Auto Resume"
    when
            Item hMode changed to 1
    then
            Thread::sleep(500)
            if(gHeating.state == ON){
                sendCommand(GY1SS8_switch, OFF)
            }
            else if(gHeating.state == OFF){
                timerHeating = createTimer(now.plusMinutes(6), [ |     // delay to allow thermal actuator to open              
                timerHeating = null
                if(hMode.state == 1){
                        sendCommand(GY1SS8_switch, ON)
                }])
            }
    end

rule "Schedule Morning"
        when
                Time cron "0 15 6 ? * MON,TUE,WED,THU,FRI *"
        then
        sendCommand(hSchedule, 1)
        if(hMode.state == 1 && hAway.state == OFF)
        {
                h_status = "Weekday morning"
                postUpdate(hStatus, h_status)
                sendCommand(hSP_GO1, hSPm_GO1.state as Number)
                sendCommand(hSP_GK1, hSPm_GK1.state as Number)
                sendCommand(hSP_GL1, hSPm_GL1.state as Number)
                sendCommand(hSP_GS1, hSPm_GS1.state as Number)
                sendCommand(hSP_FB1, hSPm_FB1.state as Number)
                sendCommand(hSP_FB2, hSPm_FB2.state as Number)
                sendCommand(hSP_FB3, hSPm_FB3.state as Number)             
        }
end

rule "Schedule Daytime"
        when
                Time cron "0 30 8 ? * MON,TUE,WED,THU,FRI *"
                or
                Item XM1AS1_presence changed to "not present"
        then
        if(hSchedule.state == 1)
        {
        sendCommand(hSchedule, 2)      
        if(hMode.state == 1 && hAway.state == OFF)
        {
                h_status = "Weekday daytime"                
                postUpdate(hStatus, h_status)
                sendCommand(hSP_GO1, hSPd_GO1.state as Number)
                sendCommand(hSP_GK1, hSPd_GK1.state as Number)
                sendCommand(hSP_GL1, hSPd_GL1.state as Number)
                sendCommand(hSP_GS1, hSPd_GS1.state as Number)
                sendCommand(hSP_FB1, hSPd_FB1.state as Number)
                sendCommand(hSP_FB2, hSPd_FB2.state as Number)
                sendCommand(hSP_FB3, hSPd_FB3.state as Number)             
        }
        }
end

rule "Schedule Evening"
        when
                Time cron "0 0 16 1/1 * ? *"
                or
                Time cron "0 32 21 1/1 * ? *"
                or
                Item hOverride changed to 3
        then
        sendCommand(hSchedule, 3)
        if(hMode.state == 1 && hAway.state == OFF)
        {
                h_status = "Evening"                
                postUpdate(hStatus, h_status)
                sendCommand(hSP_GO1, hSPe_GO1.state as Number)
                sendCommand(hSP_GK1, hSPe_GK1.state as Number)
                sendCommand(hSP_GL1, hSPe_GL1.state as Number)
                sendCommand(hSP_GS1, hSPe_GS1.state as Number)
                sendCommand(hSP_FB1, hSPe_FB1.state as Number)
                sendCommand(hSP_FB2, hSPe_FB2.state as Number)
                sendCommand(hSP_FB3, hSPe_FB3.state as Number)             
        }
end

