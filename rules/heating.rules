                sendCommand(hSP_FB2, hSPw_FB2.state as Number)
                sendCommand(hSP_FB3, hSPw_FB3.state as Number)             
        }
end   

rule "Schedule Holiday ON"
        when
                Item hAway changed to ON
        then
                h_status = "Holiday"               
                postUpdate(hStatus, h_status)
                sendCommand(hSP_GO1, hSPh_GO1.state as Number)
                sendCommand(hSP_GK1, hSPh_GK1.state as Number)
                sendCommand(hSP_GL1, hSPh_GL1.state as Number)
                sendCommand(hSP_GS1, hSPh_GS1.state as Number)
                sendCommand(hSP_FB1, hSPh_FB1.state as Number)
                sendCommand(hSP_FB2, hSPh_FB2.state as Number)
                sendCommand(hSP_FB3, hSPh_FB3.state as Number)             
end 

rule "Schedule Holiday OFF"
        when
                Item hAway changed to OFF
        then
        if(hSchedule.state == 1)
        {
                h_status = "Weekday morning"
                postUpdate(hStatus, h_status)
                sendCommand(hSP_GO1, hSPm_GO1.state as Number)
                sendCommand(hSP_GK1, hSPm_GK1.state as Number)
                sendCommand(hSP_GL1, hSPm_GL1.state as Number)
                sendCommand(hSP_GS1, hSPm_GS1.state as Number)
                sendCommand(hSP_FB1, hSPm_FB1.state as Number)
                sendCommand(hSP_FB2, hSPm_FB2.state as Number)
                sendCommand(hSP_FB3, hSPm_FB3.state as Number)             
        }
        else if(hSchedule.state == 2)
        {
                h_status = "Weekday daytime"                
                postUpdate(hStatus, h_status)
                sendCommand(hSP_GO1, hSPd_GO1.state as Number)
                sendCommand(hSP_GK1, hSPd_GK1.state as Number)
                sendCommand(hSP_GL1, hSPd_GL1.state as Number)
                sendCommand(hSP_GS1, hSPd_GS1.state as Number)
                sendCommand(hSP_FB1, hSPd_FB1.state as Number)
                sendCommand(hSP_FB2, hSPd_FB2.state as Number)
                sendCommand(hSP_FB3, hSPd_FB3.state as Number)             
        }
        else if(hSchedule.state == 3)
        {
                h_status = "Evening"                
                postUpdate(hStatus, h_status)
                sendCommand(hSP_GO1, hSPe_GO1.state as Number)
                sendCommand(hSP_GK1, hSPe_GK1.state as Number)
                sendCommand(hSP_GL1, hSPe_GL1.state as Number)
                sendCommand(hSP_GS1, hSPe_GS1.state as Number)
                sendCommand(hSP_FB1, hSPe_FB1.state as Number)
                sendCommand(hSP_FB2, hSPe_FB2.state as Number)
                sendCommand(hSP_FB3, hSPe_FB3.state as Number)             
        }
        else if(hSchedule.state == 4)
        {
                h_status = "Night"                
                postUpdate(hStatus, h_status)
                sendCommand(hSP_GO1, hSPn_GO1.state as Number)
                sendCommand(hSP_GK1, hSPn_GK1.state as Number)
                sendCommand(hSP_GL1, hSPn_GL1.state as Number)
                sendCommand(hSP_GS1, hSPn_GS1.state as Number)
                sendCommand(hSP_FB1, hSPn_FB1.state as Number)
                sendCommand(hSP_FB2, hSPn_FB2.state as Number)
                sendCommand(hSP_FB3, hSPn_FB3.state as Number)             
        }
        else if(hSchedule.state == 5)
        {
                h_status = "Weekend morning/daytime"                
                postUpdate(hStatus, h_status)
                sendCommand(hSP_GO1, hSPw_GO1.state as Number)
                sendCommand(hSP_GK1, hSPw_GK1.state as Number)
                sendCommand(hSP_GL1, hSPw_GL1.state as Number)
                sendCommand(hSP_GS1, hSPw_GS1.state as Number)
                sendCommand(hSP_FB1, hSPw_FB1.state as Number)
                sendCommand(hSP_FB2, hSPw_FB2.state as Number)
                sendCommand(hSP_FB3, hSPw_FB3.state as Number)             
        }
end 

rule "Heating Manual Status"
        when
                Item hMode changed to 0
        then
                h_status = "Manual"
                postUpdate(hStatus, h_status)
 
end               

rule "Heating Auto Status"
        when
                Item hMode changed to 1
        then
        if(hSchedule.state == 1)
        {
                h_status = "Weekday morning"
                postUpdate(hStatus, h_status)
        }
        else if(hSchedule.state == 2)
        {
                h_status = "Weekday daytime"
                postUpdate(hStatus, h_status)                
        }
        else if(hSchedule.state == 3)
        {
                h_status = "Evening"         
                postUpdate(hStatus, h_status)       
        }
        else if(hSchedule.state == 4)
        {
                h_status = "Night"  
                postUpdate(hStatus, h_status)              
        }
        else if(hSchedule.state == 5)
        {
                h_status = "Weekend morning/daytime" 
                postUpdate(hStatus, h_status)               
        }
end
