
// HEATING ZONES
// Office

var Timer timerHeating = null
var String h_status
var Timer timerSonoffReset = null

rule "Office"
    when 
            Item GO1SS4_temp changed 
            or
            Item hSP_GO1 changed
            or
            Item hMode changed to 1 
            or
            Item hGO1_Radiator changed
    then 
            if (((GO1SS4_temp.state as Number) <= ((hSP_GO1.state as Number) - (hHysteresis.state as Number))) && (hStandby.state == 0) && (GO1SS12_switch.state == ON) && (hMode.state == 1) && (hGO1_Radiator.state == 1)) {
                    sendCommand(GO1SS12_switch, OFF)
            }
            else if ((((GO1SS4_temp.state as Number) >= ((hSP_GO1.state as Number) + (hHysteresis.state as Number))) && (GO1SS12_switch.state == OFF) && (hMode.state == 1)) || (hGO1_Radiator.state == 0))  {
                    if(hStandby.state == 0 || ((GO1SS4_temp_delta.state as Number + hHysteresis.state as Number) < 0))
                    {
                        sendCommand (GO1SS12_switch, ON)
                    }
            }
    end

rule "Kitchen"
    when 
            Item GK1SS3_temp changed 
            or
            Item hSP_GK1 changed
            or
            Item hMode changed to 1
            or
            Item hGK1_Radiator changed
    then 
