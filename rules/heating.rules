rule "Schedule Weekend Morning & Daytime"
        when
                Time cron "0 30 7 ? * SAT,SUN *"
        then
        sendCommand(hSchedule, 5)
        if(hMode.state == 1 && hAway.state == OFF)
        {
                h_status = "Weekend morning/daytime"                
