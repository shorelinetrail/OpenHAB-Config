//import java.util.Map  // for timers

/*
 * LIGHTING STATE MODEL
 *   A (var a) - primary lighting mode:
 *       0 = daytime / off      1 = dusk (sunset -30)   2 = evening (sunset)
 *       3 = night              4 = dark morning        5 = night, away
 *     100 = motion active (var b holds the mode to restore when motion clears)
 *   C (var c) - hall    dark-daytime sub-state: 0 = idle, 1 = pending (debouncing), 2 = active
 *   D (var d) - kitchen dark-daytime sub-state: 0 = idle, 1 = pending (debouncing), 2 = active
 *   C/D run only while A == 0 (daytime) and are reset whenever A > 0.
 */
var Number a = 0  // primary lighting mode (see legend above)
var Number b = 0  // holding variable: mode to restore after the motion timer elapses
var Number c = 0  // hall dark-daytime sub-state (0/1/2)
var Number d = 0  // kitchen dark-daytime sub-state (0/1/2)

var Number bedTimeoutMins
var Number bedTimeoutSecs
var Number motionTimeoutMins
var Number motionTimeoutSecs
var Number motionSetpoint
var Number darkDayMinHall
var Number darkDayMaxHall
var Number darkDayMinKit
var Number darkDayMaxKit

var String light_status
var String motion_lights_status

var Timer motionTimer = null
var Timer timerHall = null
var Timer timerKitchen = null
var Timer timerMornings = null
var Timer timerBedtime = null
var Timer timerLeaveHome = null
var Timer timerDoorBell = null

/*============= TRIGGERS =============*/

// SYSTEM

rule "Reload Variables"
    when
        System started
    then
        a = A.state as Number
        b = B.state as Number
        c = C.state as Number
        d = D.state as Number
        motionTimeoutMins = Motion_Time.state as Number
        // default per-person presence so the combiner never reads NULL
        if (XM1AS1_presence_S.state == NULL) XM1AS1_presence_S.postUpdate("not present")
        if (XM1AS1_presence_J.state == NULL) XM1AS1_presence_J.postUpdate("not present")
end

// LIGHTS

// Motion Timer

rule "Motion Timer"
    when   
            Item GH1MS1_motion changed to "active"
    then 
            //logInfo("rules.rules", "Lighting mode is: " + Motion_Lights.state )
            if((motionTimer === null) && (Motion_Lights.state == ON) && (A.state == 2 || A.state == 3)){
                    motionTimeoutMins = Motion_Time.state as Number
                    motionTimeoutSecs = motionTimeoutMins * 60
                    motionSetpoint = Motion_Setpoint.state as Number
                    b = A.state as Number
                    postUpdate(B, b)
                    a = 100
                    postUpdate(A, a)
                    light_status = "Motion detected"
                    postUpdate(Light_Status, light_status)
                    //sendCommand (gHueDimmer, motionSetpoint)
                    sendCommand (GH1HB1_dimmer, motionSetpoint)
                    Thread::sleep(500)
                    sendCommand (FL1HB2_dimmer, motionSetpoint)
                    Thread::sleep(500)
                    sendCommand (FL1HB3_dimmer, motionSetpoint)
                    motionTimer = createTimer(now.plusSeconds(motionTimeoutSecs.intValue), [ |
                       motionTimer = null
                       if(A.state == 100){
                                a = B.state as Number
                                postUpdate(A, a)
                                b = 0
                                postUpdate(B, b)
                       }
                ])
            }
            else if (motionTimer !== null && A.state == 100) {
        motionTimer.reschedule(now.plusSeconds(motionTimeoutSecs.intValue))
    }
end

rule "Motion Lights Status"
/* Update Motion_Lights_Status whenever A changes: Standby (2/3), Active (100), otherwise Unavailable */
        when
                Item A changed
        then 
                if((A.state == 2) || (A.state == 3)){
                        motion_lights_status = "Standby"
                        postUpdate(Motion_Lights_Status, motion_lights_status)
                }
                else if(A.state == 100){
                        motion_lights_status = "Active"
                        postUpdate(Motion_Lights_Status, motion_lights_status)                        
                }
                else{
                        motion_lights_status = "Unavailable"
                        postUpdate(Motion_Lights_Status, motion_lights_status)
                }
end

// Dark Mornings

rule "Dark Mornings"
/* If it is 07:00 and the sun has not risen, set variable a = 4 */
        when
                Time cron "0 0 7 1/1 * ? *"
        then
                if(now.toInstant.isBefore((Astro_SunriseEnd.state as DateTimeType).getInstant)){
                        a = 4
                        postUpdate(A, a)
                }
end

rule "Dark Mornings Override"
        when
                Item GH1MS1_motion changed to "active"
        then
                if((now.getHour < 7) && (now.getHour > 3) && (A.state != 0) && (A.state != 100))
                {
                        a = 4
                        postUpdate(A, a)
                }
end

// Dark Daytime (Hall)

rule "Dark Daytime Hall"
/* When Multisensor illuminance changes, is below 'x' lx and a = 0, wait 10 minutes, then set a = 5 if the previous conditions are still true */
        when
                Item GH1MS1_illuminance changed
        then
                darkDayMinHall = Lux_Min_Hall.state as Number
                darkDayMaxHall = Lux_Max_Hall.state as Number
                if(
                        (GH1MS1_illuminance.state < darkDayMinHall) && (A.state == 0) && (C.state == 0)
                ){
                        c = 1
                        postUpdate(C, c)
                        logInfo("rules.rules", "Dark daytime hall trigger timer start")
                        if (timerHall !== null) { timerHall.cancel; timerHall = null }
                        timerHall = createTimer(now.plusMinutes(5), [ |
                        if(
                                (GH1MS1_illuminance.state < darkDayMinHall) && (C.state == 1) && (A.state == 0)
                        )
                        {
                                c = 2
                                postUpdate(C, c)
                                timerHall = null
                        }
                        else
                        {
                                c = 0
                                postUpdate(C, c)
                                timerHall = null
                        }
                ])
                }
end

rule "Dark Daytime Hall Recovered"
/* When Multisensor illuminance changes, is above 'x + y' lx and a = 5, wait 10 minutes, then set a = 0 if the previous conditions are still true */
        when
                Item GH1MS1_illuminance changed
        then
                // read threshold directly from the item - do NOT rely on the
                // global set in "Dark Daytime Hall" (null after a restart -> C
                // would stay stuck at 2 and hold the hall lights on all day)
                darkDayMaxHall = Lux_Max_Hall.state as Number
                if(
                        (GH1MS1_illuminance.state > darkDayMaxHall) && (C.state == 2)
                ){
                        // Start the 5-min confirm ONCE; do not cancel/restart on
                        // every lux change. The MS6 updates ~every 60s, so the old
                        // cancel-and-restart-on-change meant the 5-min timer never
                        // survived to fire and C never cleared.
                        if (timerHall === null) {
                        timerHall = createTimer(now.plusMinutes(5), [ |
                        if(GH1MS1_illuminance.state > darkDayMaxHall && C.state == 2){
                                c = 0
                                postUpdate(C, c)
                                sendCommand (GO1SP1_switch, "OFF")
                                sendCommand (GL1SP2_switch, "OFF")
                                sendCommand (XM1SS21_switch, "OFF")
                                sendCommand (gHueDimmer, 0)
                                sendCommand (gHueYard, 0)
                                sendCommand (gHueFront, 0)
                                sendCommand (GY1HB15_dimmer, 0)              
                        }
                        timerHall = null
                        ])
                        }
                }
end

rule "Dark Day Hall Lights Present"
/* When hall dark-daytime becomes active (C == 2): turn on yard/front Hue and, if present, hall plugs + dimmers */
        when   
                Item C changed to 2
        then    
                sendCommand (GO1SP1_switch, "ON")                
                sendCommand (gHueYard, 33)
                sendCommand (gHueFront, HueFrontDarkDaytime_Setpoint.state as Number)
                sendCommand (GY1HB15_dimmer, 25)
                if(XM1AS1_presence.state.toString == "present"){
                        //sendCommand (GL1SP2_switch, "ON")
                        sendCommand (XM1SS21_switch, "ON")
                        sendCommand (gHueDimmer, DarkHall_Setpoint.state as Number)
                }
end

// Dark Daytime (Kitchen)

rule "Dark Daytime Kitchen"
/* When the kitchen Sonoff illuminance falls below Lux_Min_Kitchen while in daytime mode (A == 0), wait 5 minutes, then set D = 2 if still dark */
        when
                Item GK1SS1_illuminance changed
        then
                darkDayMinKit = Lux_Min_Kitchen.state as Number
                darkDayMaxKit = Lux_Max_Kitchen.state as Number
                if(
                        (GK1SS1_illuminance.state < darkDayMinKit) && (A.state == 0) && (D.state == 0)
                ){
                        d = 1
                        postUpdate(D, d)
                        logInfo("rules.rules", "Dark daytime kitchen trigger timer start")
                        if (timerKitchen !== null) { timerKitchen.cancel; timerKitchen = null }
                        timerKitchen = createTimer(now.plusMinutes(5), [ |
                        if(
                                (GK1SS1_illuminance.state < darkDayMinKit) && (D.state == 1) && (A.state == 0)
                        )
                        {
                                d = 2
                                postUpdate(D, d)
                                timerKitchen = null
                        }
                        else
                        {
                                d = 0
                                postUpdate(D, d)
                                timerKitchen = null
                        }
                ])
                }
end

rule "Dark Daytime Kitchen Recovered"
/* When the kitchen brightens above Lux_Max_Kitchen while dark-day kitchen is active (D == 2), wait 5 minutes, then set D = 0 and turn the kitchen lights off */
        when
                Item GK1SS1_illuminance changed
        then
                darkDayMaxKit = Lux_Max_Kitchen.state as Number
                if(
                        (GK1SS1_illuminance.state > darkDayMaxKit) && (D.state == 2)
                ){
                        // Start the 5-min confirm ONCE (see Hall note above).
                        if (timerKitchen === null) {
                        timerKitchen = createTimer(now.plusMinutes(5), [ |
                        if(GK1SS1_illuminance.state > darkDayMaxKit && D.state == 2){
                                d = 0
                                postUpdate(D, d)
                                sendCommand (gHueKitchen, 0)
                                sendCommand (gSonoff, "OFF")
                        }
                        timerKitchen = null
                        ])
                        }
                }
end

rule "Dark Day Kitchen Lights Present"
/* When kitchen dark-daytime becomes active (D == 2) AND someone is home: dim the kitchen Hue
   and turn on the kitchen Sonoff relays. When away, the kitchen stays dark. */
        when   
                Item D changed to 2
        then    
                if(XM1AS1_presence.state.toString == "present"){
                        if(GK1HB4_dimmer.state < 5){
                                sendCommand (gHueKitchen, DarkKitchen_Setpoint.state as Number)
                        }
                        sendCommand (gSonoff, "ON")
                }
end



// Dark Daytime (General)

rule "Dark Daytime Status (Hall)"

        when
                Item C changed
        then
                if(
                        ((C.state == 2) && (D.state == 2))
                ){
                        light_status = "Dark day hall/kitchen"
                        postUpdate(Light_Status, light_status)
                }
                else
                {
                        if(
                                ((D.state == 2) && (C.state != 2))
                        ){
                                light_status = "Dark day kitchen"
                                postUpdate(Light_Status, light_status)
                        }
                        if(
                                ((C.state == 2) && (D.state != 2))
                        ){
                                light_status = "Dark day hall"
                                postUpdate(Light_Status, light_status)
                        }
                        if(
                                ((D.state == 0) && (C.state == 0) && (A.state == 0))
                        ){
                                light_status = "Off"
                                postUpdate(Light_Status, light_status)
                        }
                }
        end

rule "Dark Daytime Status (Kitchen)"

        when
                Item D changed
        then
                if(
                        ((C.state == 2) && (D.state == 2))
                ){
                        light_status = "Dark day hall/kitchen"
                        postUpdate(Light_Status, light_status)
                }
                else
                {
                        if(
                                ((C.state == 2) && (D.state != 2))
                        ){
                                light_status = "Dark day hall"
                                postUpdate(Light_Status, light_status)
                        }
                        if(
                                ((D.state == 2) && (C.state != 2))
                        ){
                                light_status = "Dark day kitchen"
                                postUpdate(Light_Status, light_status)
                        }
                        if(
                                ((D.state == 0) && (C.state == 0) && (A.state == 0))
                        ){
                                light_status = "Off"
                                postUpdate(Light_Status, light_status)
                        }
                }
        end

rule "Left Home"
/* When presence changes to away, wait 5 minutes (covers brief WiFi drops), then react
   by lighting mode:
     - dark daytime (C/D == 2): shut the interior down, leave exterior on as security
     - dusk / evening (A == 1 or 2): OCCUPIED LOOK - keep hall (gHueDimmer), plugs and
       exterior on; only the kitchen is switched off
     - night (A == 3): go to night-away (a = 5) and make the interior dark
     - bright daytime (else): just make sure the kitchen is off */
        when
                Item XM1AS1_presence changed to "not present"
        then
                if(timerLeaveHome !== null){ timerLeaveHome.cancel; timerLeaveHome = null }
                timerLeaveHome = createTimer(now.plusMinutes(5), [ |
                        timerLeaveHome = null
                        if(XM1AS1_presence.state.toString == "not present"){      // still away after the grace period
                                if((C.state == 2) || (D.state == 2)){             // dark daytime active
                                        sendCommand (GL1SP2_switch, "OFF")
                                        sendCommand (XM1SS21_switch, "OFF")
                                        sendCommand (gHueDimmer, 0)
                                        sendCommand (gHueKitchen, 0)
                                        sendCommand (gHueGlass, 0)
                                        sendCommand (GK1SS1_switch, "OFF")
                                        sendCommand (GK1SS2_switch, "OFF")
                                }
                                else if(A.state == 1 || A.state == 2){            // dusk / evening - occupied look
                                        sendCommand (gHueKitchen, 0)             // hall, plugs and exterior stay on
                                        sendCommand (gHueGlass, 0)
                                        sendCommand (GK1SS1_switch, "OFF")
                                        sendCommand (GK1SS2_switch, "OFF")
                                        sendCommand (XM1SS21_switch, "OFF")
                                }
                                else if(A.state == 3){                            // night - left after lights-out
                                        a = 5
                                        postUpdate(A, a)
                                        sendCommand (gHueDimmer, 0)
                                        sendCommand (gHueKitchen, 0)
                                        sendCommand (FB1SP3_switch, "OFF")
                                }
                                else {                                            // bright daytime
                                        sendCommand (gHueKitchen, 0)
                                        sendCommand (gHueGlass, 0)
                                }
                        }
                ])
end

rule "Dark Day Lights Return"
// When presence = present and variable a = 5, turn on Smart Plugs, turn on Sonoff Relays and dim Hue bulbs to 50% */
        when   
                Item XM1AS1_presence changed to "present"
        then    
                sendCommand(BlueIris_trigger, "profile=1")
                if(A.state == 0 && C.state == 2){               // Dark daytime hall active
                        sendCommand (GO1SP1_switch, "ON")
                        sendCommand (GL1SP2_switch, "ON")
                        sendCommand (XM1SS21_switch, "ON")
                        sendCommand (gHueDimmer, DarkHall_Setpoint.state as Number)
                }
                if (A.state == 0 && D.state == 2){              // Dark daytime kitchen
                        sendCommand (gSonoff, "ON")
                        sendCommand (gHueKitchen, DarkKitchen_Setpoint.state as Number)
                }
                if (A.state == 1){  // Lighting mode dusk
                        sendCommand (gHueKitchen, KitDusk_Setpoint.state as Number)
                        //sendCommand (gHueGlass, 25)
                        sendCommand (GK1SS1_switch, ON)
                        sendCommand (GK1SS2_switch, ON)
                        sendCommand (XM1SS21_switch, ON)
                }
                if (A.state == 2 || A.state == 100){  // Lighting mode evening
                        sendCommand (gHueKitchen, KitEvening_Setpoint.state as Number)
                        //sendCommand (gHueGlass, 25)
                        sendCommand (GK1SS1_switch, ON)
                        sendCommand (GK1SS2_switch, ON)
                        sendCommand (XM1SS21_switch, ON)
                }
end

// MORNING LIGHTS

rule "Morning Override"
        when
                Item Lighting_Mode changed to 4
        then
                a = 4
                postUpdate(A, a)
end

rule "Light Mornings"
/* If the sun rises before 07:00, return to daytime mode (a = 0).
   Dark-day re-detection after sunrise is handled by the continuous
   "Dark Daytime Hall" / "Dark Daytime Kitchen" rules. */
        when
                Channel 'astro:sun:local:rise#event' triggered START
        then
                if(now.getHour < 7){
                        a = 0
                        postUpdate(A, a)
                }
end

// Evening & Night

rule "Sunset -30 Minutes"
/* Set variable a = 1 when it is 30 minutes prior to sunset, set item A to equal variable a */
        when
                Channel "astro:sun:c7d0dedc:set#event" triggered END
        then 
                a = 1
                c = 0
                d = 0 
                postUpdate(C, c)
                postUpdate(A, a)
                postUpdate(B, b)
                sendCommand(gChristmas, ON)
                logInfo("Christmas.rules", "gChristmas ON - sunset -30 mins" )

end

rule "Midnight"
        when
                Time cron "0 0 0 1/1 * ? *"
        then
                sendCommand(gHueFront, HueFrontMidnight_Setpoint.state as Number)
                sendCommand(gHueYard, 30)
                sendCommand(Presence_Override, OFF)

end

rule "Sunset"
/* Set variable a = 2 when sunset ends, set item A to equal variable a */
        when
                Channel 'astro:sun:local:set#event' triggered END
        then 
                a = 2
                postUpdate(A, a)
end

rule "Night Lights Away"
/* Set variable a = 3 when it is 23:00 if not present */
        when
                Time cron "0 0 23 1/1 * ? *"
        then
                if(XM1AS1_presence.state.toString == "not present"){
                        a = 3
                        postUpdate(A, a)
                }
end

rule "Night Lights Reset Arrive Home"
/* Set variable a = 2 when presence changes to present, it is after 23:00 and variable a = 0 */
        when
                Item XM1AS1_presence changed to "present"
        then
                if(((now.getHour > 22) || (now.getHour < 4)) && (A.state == 5)){
                        a = 2
                        postUpdate(A, a)
                        sendCommand (gHueKitchen, KitEvening_Setpoint.state as Number)
                }

                else if(A.state == 1){
                        sendCommand (gHueKitchen, KitDusk_Setpoint.state as Number)
                }

                else if(A.state == 2){
                        sendCommand (gHueKitchen, KitEvening_Setpoint.state as Number)
                }

end

/*============ ACTIONS ============*/

rule "Reset Dark Day Variables"

        when
                Item A changed
        then
                if(
                        A.state > 0
                )
                {
                        c = 0
                        d = 0 
                        postUpdate(C, c)
                        postUpdate(D, d)
                }
end                

rule "Dark Morning Lights On"
/* Turn on Smart Plugs (except bedroom), turn on Sonoff Relays and dim Hue bulbs to 50% when item A changes to 4 */
        when   
                Item A changed to 4
        then    
                light_status = "Dark morning"
                postUpdate(Light_Status, light_status)
                sendCommand (GO1SP1_switch, "ON")
                sendCommand (GL1SP2_switch, "ON")
                sendCommand (XM1SS21_switch, "ON")
                sendCommand (gSonoff, "ON")
                sendCommand (gHueDimmer, DarkMorning_Setpoint.state as Number)
                sendCommand (gHueYard, 33)
                sendCommand (gHueFront, HueFrontDarkMorning_Setpoint.state as Number)
                sendCommand (GY1HB15_dimmer, 25)
end

rule "Dark Morning Lights Off"
/* 30 minutes after sunrise, turn off the morning-boost lights; if we were in
   dark-morning mode (a = 4), return to daytime (a = 0). Dark-day re-detection
   is handled by the continuous "Dark Daytime Hall" / "Dark Daytime Kitchen" rules. */
        when   
                Channel 'astro:sun:local:rise#event' triggered START
        then    
                
                timerMornings = createTimer(now.plusMinutes(30), [ |
                timerMornings = null

/*                darkDayMinHall = Lux_Min_Hall.state as Number
                darkDayMaxHall = Lux_Max_Hall.state as Number

                if(
                        (GH1MS1_illuminance.state < darkDayMinHall) 
                ){
                        c = 1
                        postUpdate(C, c)
                }

                darkDayMinKit = Lux_Min_Kitchen.state as Number
                darkDayMaxKit = Lux_Max_Kitchen.state as Number

                if(
                        (GK1SS1_illuminance.state < darkDayMinKit)
                ){
                        d = 1
                        postUpdate(D, d)
                }
*/
                // End the overnight / morning-boost outdoor Hues only once it is light.
                // If it is still dark they are left on and the "Lights Off" rule (fired
                // when A returns to 0 below) hands them to dark-day, so they never drop out.
                darkDayMinHall = Lux_Min_Hall.state as Number
                if(!((GH1MS1_illuminance.state instanceof Number) && ((GH1MS1_illuminance.state as Number) < darkDayMinHall))){
                        sendCommand (gHueYard, 0)
                        sendCommand (gHueFront, 0)
                        sendCommand (GY1HB15_dimmer, 0)
                }
                if(A.state == 4){
                        a = 0
                        postUpdate(A, a)

/*                if(C.state == 1){
                        c = 2
                        postUpdate(C, c)
  
                }

                if(D.state == 1){
                        d = 2
                        postUpdate(D, d)
  
                }
*/
                }])

end

rule "Dusk Lights"
/* Turn on Smart Plugs, turn on Sonoff Relays and dim Hue bulbs to 75% when item A changes to 1 */
        when   
                Item A changed to 1
        then    
                light_status = "Dusk"
                postUpdate(Light_Status, light_status)
                /*logInfo("rules.rules", "Lighting mode is: " + Light_Status.state )*/
                sendCommand (gPlugs, "ON")
                //sendCommand (GK1SS2_switch, "ON")
                sendCommand (gHueDimmer, Dusk_Setpoint.state as Number)
                sendCommand (gHueYard, 15)
                sendCommand (gHueFront, HueFrontDusk_Setpoint.state as Number)
                sendCommand (GY1HB15_dimmer, 25)
                if(XM1AS1_presence.state.toString == "present"){
                      sendCommand (gHueKitchen, KitDusk_Setpoint.state as Number)
                      sendCommand (GK1SS1_switch, "ON")
                      sendCommand (GK1SS2_switch, "ON")
                      sendCommand (XM1SS21_switch, "ON")                                
                }
end

rule "Evening Lights"
/* Dim Hue bulbs to 30% when item A changes to 2 */
        when   
                Item A changed to 2
        then    
                light_status = "Evening"
                postUpdate(Light_Status, light_status)
                sendCommand (gPlugs, "ON")
                //sendCommand (GK1SS1_switch, "ON")
                sendCommand (gHueDimmer, Evening_Setpoint.state as Number) 
                sendCommand (gHueYard, 45)
                sendCommand (gHueFront, HueFrontEvening_Setpoint.state as Number)
                sendCommand (GY1HB15_dimmer, 66)
                if(XM1AS1_presence.state.toString == "present"){
                      sendCommand (gHueKitchen, KitEvening_Setpoint.state as Number)          
                }
                sendCommand (Lighting_Mode, "1")
end

rule "Kitchen Lights"
        when
                Item GK1_mode changed
        then
                if(GK1_mode.state == 1)
                {
                        sendCommand (gHueKitchen, KitEvening_Setpoint.state as Number)
                        sendCommand (gHueGlass, 0)
                }
                if(GK1_mode.state == 2)
                {
                        sendCommand (GK1HB4_dimmer, 0)
                        sendCommand (GK1HB5_dimmer, 0)
                        sendCommand (GK1HB6_dimmer, 5)
                        sendCommand (GK1HB7_dimmer, 5)
                        sendCommand (GK1HB8_dimmer, 25)
                        sendCommand (GK1HB9_dimmer, 25)
                        sendCommand (gHueTable, 40)
                        sendCommand (gHueGlass, 0)
                        sendCommand (GK1SS1_switch, OFF)
                        sendCommand (GK1SS2_switch, OFF)
                }
                if(GK1_mode.state == 3)
                {
                        sendCommand (GK1HB4_dimmer, 100)
                        sendCommand (GK1HB5_dimmer, 100)
                        sendCommand (GK1HB6_dimmer, 100)
                        sendCommand (GK1HB7_dimmer, 100)
                        sendCommand (GK1HB8_dimmer, 100)
                        sendCommand (GK1HB9_dimmer, 100)
                        sendCommand (gHueTable, 25)
                        sendCommand (gHueGlass, 25)
                        sendCommand (GK1SS1_switch, ON)
                        sendCommand (GK1SS2_switch, ON)
                }
end

rule "Night lights"
/* Turn off Smart Plugs, turn off Sonoff Relays and dim Hue bulbs when item A changes to 3 */
        when   
                Item A changed to 3
        then    
                light_status = "Night"
                postUpdate (Light_Status, light_status)
                sendCommand (GO1SP1_switch, "OFF")
                sendCommand (GL1SP2_switch, "OFF")
                sendCommand (XM1SS21_switch, "OFF")
                sendCommand (gSonoff, "OFF")
                sendCommand (GH1HB1_dimmer, NightHallFront_Setpoint.state as Number)
                sendCommand (FL1HB2_dimmer, NightHallMid_Setpoint.state as Number)
                sendCommand (FL1HB3_dimmer, NightHallRear_Setpoint.state as Number)
                sendCommand (gHueKitchen, 0)
                sendCommand (Lighting_Mode, "2") 
                sendCommand (FB1BE3_position, 1)

                if(XM1AS1_presence.state.toString == "not present"){
                        a = 5
                        postUpdate(A, a)
                        sendCommand (FB1SP3_switch, "OFF")
                }

                else {
                        bedTimeoutMins = Bed_Time.state as Number
                        bedTimeoutSecs = bedTimeoutMins * 60
                        if (timerBedtime !== null) { timerBedtime.cancel; timerBedtime = null }
                        timerBedtime = createTimer(now.plusSeconds(bedTimeoutSecs.intValue), [ |
                        if(A.state == 3 || B.state == 3){
                        sendCommand (FB1SP3_switch, "OFF")
                        } 
                ])}                             
end

rule "Lights Off"
/* When entering daytime (A = 0): turn plugs/relays off. Each Hue zone is only
   switched off if it is actually light; if a zone is still dark, dark-day is
   engaged so its Hues go to dark-day levels instead of dropping out. */
        when   
                Item A changed to 0
        then    
                /*Thread::sleep(1000)
                if(A.state !== 100)
                        {
                        sendCommand(GH1HB1_dimmer, Evening_Setpoint.state as Number)
                        }   
                */
                light_status = "Off"
                postUpdate(Light_Status, light_status)
                sendCommand (gPlugs, "OFF")
                sendCommand (gSonoff, "OFF")
                /* Only switch the Hue groups off if the zone is actually light. If it is
                   still dark, engage dark-day instead so the Hues move straight to their
                   dark-day levels (via the "Dark Day ... Lights Present" rules) rather
                   than dropping to 0 and waiting for the continuous rules to re-detect. */
                darkDayMinHall = Lux_Min_Hall.state as Number
                darkDayMinKit  = Lux_Min_Kitchen.state as Number
                val hallLux = GH1MS1_illuminance.state
                val kitLux  = GK1SS1_illuminance.state

                if((hallLux instanceof Number) && ((hallLux as Number) < darkDayMinHall)){
                        c = 2
                        postUpdate(C, c)                 // -> "Dark Day Hall Lights Present" sets yard/front/GY1HB15 (+ ceiling if present)
                        if(XM1AS1_presence.state.toString == "not present"){
                                sendCommand (gHueDimmer, 0)   // away: keep the hall ceiling off (yard/front stay on as security)
                        }
                }
                else {
                        sendCommand (gHueDimmer, 0)
                        sendCommand (gHueYard, 0)
                        sendCommand (gHueFront, 0)
                        sendCommand (GY1HB15_dimmer, 0)
                }

                if((kitLux instanceof Number) && ((kitLux as Number) < darkDayMinKit)){
                        d = 2
                        postUpdate(D, d)                 // -> "Dark Day Kitchen Lights Present" sets the kitchen Hue (only when home)
                        if(XM1AS1_presence.state.toString == "not present"){
                                sendCommand (gHueKitchen, 0)   // away: keep the kitchen Hue off
                        }
                }
                else {
                        sendCommand (gHueKitchen, 0)
                }
                sendCommand (Lighting_Mode, "3")     
end

rule "Lighting Mode Override"
        when
                Item Lighting_Mode changed
        then
        if(Lighting_Mode.state == "1"){
                a = 2
                postUpdate(A, a)
        }
        else if(Lighting_Mode.state == "2"){
                a = 3
                postUpdate(A, a)
        }
        else if(Lighting_Mode.state == "3"){
                a = 0
                postUpdate(A, a)
        }
end

// --- Two-phone presence combiner -------------------------------------------
// Each phone's Tasker POSTs its own item (Ste -> _S, Jacqui -> _J) as the
// strings "present" / "not present". This rule owns the household
// XM1AS1_presence: home if EITHER phone is home. The != guards mean the
// household item only *changes* on a real transition, so "Left Home" fires
// only when the LAST person leaves and "Dark Day Lights Return" only on the
// FIRST arrival - not when one phone drops while the other is still home.
rule "Combine Presence"
    when
        Item XM1AS1_presence_S changed or
        Item XM1AS1_presence_J changed
    then
        val sHome = (XM1AS1_presence_S.state.toString == "present")
        val jHome = (XM1AS1_presence_J.state.toString == "present")
        if (sHome || jHome) {
            if (XM1AS1_presence.state.toString != "present")
                XM1AS1_presence.sendCommand("present")
        } else {
            if (XM1AS1_presence.state.toString != "not present")
                XM1AS1_presence.sendCommand("not present")
        }
end


