var Number GY1SS22Level = 0

rule "Water Butt Level"
    when
            Item GY1SS22_distance changed 
    then
        if(GY1SS22_MO.state == OFF){
            if(GY1SS22_distance.state < 1000){
                GY1SS22Level = (960 - GY1SS22_distance.state as Number) / (960) * 100
                postUpdate(GY1SS22_level, GY1SS22Level)        
                }
            }
    end