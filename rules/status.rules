// Status

// Add WiFi RSSI
// Add a check of up time to provide status alarm
// Refresh button

import org.eclipse.smarthome.core.types.UnDefType  // OH2; for OH3 use org.openhab.core.types.UnDefType
import org.eclipse.smarthome.model.script.ScriptServiceUtil

// --- Pushover (OH5 binding) reusable lambdas (null-guarded: log + return if offline) ---
val org.eclipse.xtext.xbase.lib.Functions$Function1<String, Boolean> pushover = [ String message |
    val actions = getActions("pushover", "pushover:pushover-account:account")
    if (actions === null) {
        logWarn("pushover", "Pushover offline - message dropped: " + message)
        false
    } else {
        actions.sendMessage(message)
    }
]
val org.eclipse.xtext.xbase.lib.Functions$Function1<String, String> pushoverEmergency = [ String message |
    val actions = getActions("pushover", "pushover:pushover-account:account")
    if (actions === null) {
        logWarn("pushover", "Pushover offline - emergency dropped: " + message)
        null
    } else {
        actions.sendPriorityMessage(message, null, 2)
    }
]
val org.eclipse.xtext.xbase.lib.Functions$Function1<String, Boolean> cancelPushoverEmergency = [ String receipt |
    val actions = getActions("pushover", "pushover:pushover-account:account")
    if (actions === null) {
        logWarn("pushover", "Pushover offline - cannot cancel emergency: " + receipt)
        false
    } else {
        actions.cancelPriorityMessage(receipt)
    }
]

var Timer GK1SS1_timer = null
var Number phoneDelay
var Timer timerPhoneCharging = null

/*rule "GK1-SS1 Status"
    when   
            Time cron "0 0/1 * 1/1 * ? *"
    then 
        postUpdate(GK1SS1_status, NULL)
        GK1SS1_timer = createTimer(now.plusSeconds(10), [ |
        GK1SS1_timer = null
        if(GK1SS1_status.state == NULL)
        {
            postUpdate(GK1SS1_ok, "Error")
        }
        else
        {
