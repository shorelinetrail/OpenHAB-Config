rule "Gate Remote Single"
//improve by checking if timer is running from above
    when   
            Item gateRemoteSingle changed to "ON"
    then 
        sendCommand(gateRemoteSingle, "OFF")
        if(gateRemoteEnable.state == ON)
        {
            sendCommand(GY1SS9_switch, "ON")
        }
end