// --- Pushover (OH5 binding) reusable lambda (null-guarded: log + return if offline) ---
val org.eclipse.xtext.xbase.lib.Functions$Function1<String, Boolean> pushover = [ String message |
    val actions = getActions("pushover", "pushover:pushover-account:account")
    if (actions === null) {
        logWarn("pushover", "Pushover offline - message dropped: " + message)
        false
    } else {
        actions.sendMessage(message)
    }
]

var Number blindsSP
var Number blindsDelay

var Timer timerBlinds = null

var Timer GO1BE1_timer = null
var Timer GL1BE2_timer = null
var Timer FB1BE3_timer = null
var Timer FB1BE3_timer1 = null

var Number e = 0  // used for blinds control (surnise)
var Number f = 0  // used for blinds control (post-sunrise)

var Number GO1BE1_retry = 0
var Number GL1BE2_retry = 0
var Number FB1BE3_retry = 0

var GO1BE1_lastcommand = now
var GL1BE2_lastcommand = now
var FB1BE3_lastcommand = now

var Number GO1BE1_command = 0
var Number GL1BE2_command = 0
var Number FB1BE3_command = 0

