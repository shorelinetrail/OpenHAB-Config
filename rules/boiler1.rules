// --- Pushover (OH5 binding) reusable lambda (null-guarded: log + return if offline) ---
val org.eclipse.xtext.xbase.lib.Functions$Function1<String, Boolean> pushover = [ String message |
    val actions = getActions("pushover", "pushover:pushover-account:account")
    if (actions === null) {
        logWarn("pushover", "Pushover offline - message dropped: " + message)
        false
    } else {
        actions.sendMessage(message)
    }
]

var Number boiler_delta = 0
var Number boiler_runtime = 0
var Number boiler_runtime_week = 0
var Number boiler_runtime_month = 0
var Timer hCheck = null
var Timer hRetry = null
var Number boiler_retry = 0

rule "Boiler Differential"
    when
        Item GY1NM2_temp1 changed 
    then
        boiler_delta = (GY1NM2_temp1.state as Number) - (GY1NM2_temp2.state as Number)
        postUpdate(GY1NM2_delta, boiler_delta)
end

