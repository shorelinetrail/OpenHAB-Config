rule "Boiler Run Time"
    when
        Time cron "0 0/1 * 1/1 * ? *"
    then
        if(GY1NM2_temp1.state > 60){
            boiler_runtime = boiler_runtime + 1
            boiler_runtime_week = boiler_runtime_week + 1
            boiler_runtime_month = boiler_runtime_month + 1
            postUpdate(hRuntimeToday, boiler_runtime)
            postUpdate(hRuntimeThisWeek, boiler_runtime_week / 60)
            postUpdate(hRuntimeThisMonth, boiler_runtime_month / 60)
        }
end

rule "Boiler Run Time Reset Daily"
    when
        Time cron "0 0 0 1/1 * ? *"
    then
        postUpdate(hRuntimeYesterday, boiler_runtime)
        boiler_runtime = 0
        postUpdate(hRuntimeToday, boiler_runtime)
end

rule "Boiler Run Time Reset Weekly"
    when
        Time cron "0 0 0 ? * SUN *"
    then
        postUpdate(hRuntimeLastWeek, boiler_runtime_week)
        boiler_runtime_week = 0
        postUpdate(hRuntimeThisWeek, boiler_runtime_week)
end

rule "Boiler Run Time Reset Monthly"
    when
        Time cron "0 0 0 1 1/1 ? *"
    then
        postUpdate(hRuntimeLastMonth, boiler_runtime_month)
        boiler_runtime_month = 0
        postUpdate(hRuntimeThisMonth, boiler_runtime_month)
end