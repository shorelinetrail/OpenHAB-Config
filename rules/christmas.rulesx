var Timer christmasTimer = null
var Timer christmasTimer1 = null

rule "Schedule Morning ON"
        when
                Time cron "0 0 7 1/1 * ? *"
        then
                if(Christmas_Auto.state == ON){
                    sendCommand(gChristmas, ON)
                    logInfo("Christmas.rules", "gChristmas ON - schedule morning" )
                }
end

