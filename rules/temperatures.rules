rule "Clear Min/Max Weekly Temperatures"
when
    Time cron "	0 1 0 ? * MON * "
then
    postUpdate(Temp_Week_Max, GY1SS8_temp.state as Number)
    postUpdate(Temp_Week_Max_Time, new DateTimeType)
    temp1 = Temp_Week_Max_Time.state.format("%1$tA" + ", " + "%1$tR")
    postUpdate(Temp_Week_Max_Time_Format, Temp_Week_Max.state + " °C (" + temp1 + ")")    
    
    postUpdate(Temp_Week_Min, GY1SS8_temp.state as Number)
    postUpdate(Temp_Week_Min_Time, new DateTimeType)
    temp1 = Temp_Week_Min_Time.state.format("%1$tA" + ", " + "%1$tR")
    postUpdate(Temp_Week_Min_Time_Format, Temp_Week_Min.state + " °C (" + temp1 + ")")    
end

