var String temp
var String temp1
var String temp2
var String temp3
var String temp4

rule "Min/Max Temperatures Daily"
when
    Item GY1SS8_temp changed
then
    if(
        Temp_Today_Max.state == NULL
    ){
        postUpdate(Temp_Today_Max, GY1SS8_temp.state as Number)
        postUpdate(Temp_Today_Max_Time, new DateTimeType)
        temp = Temp_Today_Max_Time.state.format("%1$tR")
        postUpdate(Temp_Today_Max_Time_Format, Temp_Today_Max.state + " °C (" + temp + ")")    
    } 
    if(
        GY1SS8_temp.state as Number > Temp_Today_Max.state as Number
    ){
        postUpdate(Temp_Today_Max, GY1SS8_temp.state as Number)
        postUpdate(Temp_Today_Max_Time, new DateTimeType)
        temp = Temp_Today_Max_Time.state.format("%1$tR")
        postUpdate(Temp_Today_Max_Time_Format, Temp_Today_Max.state + " °C (" + temp + ")")    
    }        
    if(
        Temp_Today_Min.state == NULL
    ){
        postUpdate(Temp_Today_Min, GY1SS8_temp.state as Number)
        postUpdate(Temp_Today_Min_Time, new DateTimeType)
        temp = Temp_Today_Min_Time.state.format("%1$tR")
        postUpdate(Temp_Today_Min_Time_Format, Temp_Today_Min.state + " °C (" + temp + ")")    
        }
    if(
        Temp_Today_Min.state as Number > GY1SS8_temp.state as Number
    ){
        postUpdate(Temp_Today_Min, GY1SS8_temp.state as Number)
        postUpdate(Temp_Today_Min_Time, new DateTimeType)
        temp = Temp_Today_Min_Time.state.format("%1$tR")
        postUpdate(Temp_Today_Min_Time_Format, Temp_Today_Min.state + " °C (" + temp + ")")    
    }
end

rule "Clear Min/Max Daily Temperatures"
when
    Time cron "	0 7 0 1/1 * ? * "
then
    postUpdate(Temp_Today_Max, GY1SS8_temp.state as Number)
    postUpdate(Temp_Today_Max_Time, new DateTimeType)
    temp = Temp_Today_Max_Time.state.format("%1$tR")
    postUpdate(Temp_Today_Max_Time_Format, Temp_Today_Max.state + " °C (" + temp + ")")    
    
    postUpdate(Temp_Today_Min, GY1SS8_temp.state as Number)
    postUpdate(Temp_Today_Min_Time, new DateTimeType)
    temp = Temp_Today_Min_Time.state.format("%1$tR")
    postUpdate(Temp_Today_Min_Time_Format, Temp_Today_Min.state + " °C (" + temp + ")")    
end

